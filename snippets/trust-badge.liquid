<span class="marketplace-marquee__item">
  <span class="marketplace-marquee__icon marketplace-marquee__icon--{{ icon }}" aria-hidden="true">
    {%- case icon -%}
      {%- when 'reviews' -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M10 1.9 12.6 7l5.6.82-4.05 3.95.95 5.59L10 14.71 4.85 17.36l.98-5.59L1.77 7.82 7.37 7 10 1.9z"></path>
        </svg>
      {%- when 'photos' -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M4.1 3.2h11.8c1.1 0 1.9.8 1.9 1.9v9.8c0 1.1-.8 1.9-1.9 1.9H4.1c-1.1 0-1.9-.8-1.9-1.9V5.1c0-1.1.8-1.9 1.9-1.9zm1.1 10.4h9.6l-2.5-3.1a1 1 0 0 0-1.55-.05l-1.33 1.56-1.32-1.57a1 1 0 0 0-1.53 0L5.2 13.6zm3-5.7a1.3 1.3 0 1 0 0-2.6 1.3 1.3 0 0 0 0 2.6z"></path>
        </svg>
      {%- when 'pricing' -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M10 2.5c.55 0 1 .45 1 1v.65c2.14.23 3.75 1.52 3.75 3.28 0 .55-.45 1-1 1s-1-.45-1-1c0-.69-1.06-1.3-2.75-1.3S7.25 6.79 7.25 7.48c0 .82.94 1.24 3.36 1.78 2.65.59 4.39 1.47 4.39 3.74 0 1.9-1.68 3.18-4 3.44v.56c0 .55-.45 1-1 1s-1-.45-1-1v-.6c-2.33-.28-4-1.68-4-3.59 0-.55.45-1 1-1s1 .45 1 1c0 .97 1.26 1.67 3 1.67s3-.7 3-1.65c0-.86-.71-1.36-2.95-1.86-2.72-.61-4.8-1.35-4.8-3.65 0-1.8 1.64-3.05 3.75-3.28V3.5c0-.55.45-1 1-1z"></path>
        </svg>
      {%- when 'themes' -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M10 1.75c1.06 2.42 2.86 4.47 5.12 5.83-2.26 1.35-4.06 3.41-5.12 5.82-1.06-2.41-2.86-4.47-5.12-5.82C7.14 6.22 8.94 4.17 10 1.75zm6.35 9.75.77 1.8 1.88.17-1.42 1.25.42 1.83-1.65-.98-1.64.98.42-1.83-1.42-1.25 1.88-.17.76-1.8z"></path>
        </svg>
      {%- when 'materials' -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M6.1 2.75h7.8c.5 0 .9.4.9.9s-.4.9-.9.9h-.45v5.64c0 2.62-1.95 4.73-4.36 4.73S4.74 12.89 4.74 10.27V4.55H4.3c-.5 0-.9-.4-.9-.9s.4-.9.9-.9h1.8zm.42 1.8v5.72c0 1.61 1.16 2.92 2.58 2.92s2.58-1.31 2.58-2.92V4.55H6.52z"></path>
        </svg>
      {%- when 'design' -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M10 2.25 16.6 5v4.54c0 4.02-2.61 6.45-6.6 8.21-3.99-1.76-6.6-4.19-6.6-8.21V5L10 2.25zm-1.1 8.94 3.88-3.9a.9.9 0 0 1 1.28 1.27l-4.52 4.55a.9.9 0 0 1-1.28 0L5.9 10.74a.9.9 0 1 1 1.27-1.28l1.73 1.73z"></path>
        </svg>
      {%- when 'clean' -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M10 2.3c1.75 2.3 4.58 6.43 4.58 9.42 0 2.92-2.05 5.28-4.58 5.28s-4.58-2.36-4.58-5.28c0-2.99 2.83-7.12 4.58-9.42zm2.02 10.24c-.38 1.14-1.21 1.83-2.25 1.83-.5 0-.9.4-.9.9s.4.9.9.9c1.86 0 3.43-1.23 3.96-2.82.16-.47-.11-.98-.58-1.13a.9.9 0 0 0-1.13.32z"></path>
        </svg>
      {%- else -%}
        <svg viewBox="0 0 20 20" focusable="false">
          <path d="M10 1.9 12.6 7l5.6.82-4.05 3.95.95 5.59L10 14.71 4.85 17.36l.98-5.59L1.77 7.82 7.37 7 10 1.9z"></path>
        </svg>
    {%- endcase -%}
  </span>
  <span class="marketplace-marquee__label">{{ label }}</span>
</span>
