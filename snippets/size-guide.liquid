    <div class="size-guide-popup__tip">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
      </svg>
      <p>For between sizes, we recommend sizing up for comfort and room for growth. Measurements may vary by ±0.5 inches.</p>
    </div>

    <p class="size-guide-popup__note">
      <strong>Care Instructions:</strong> Machine wash cold with similar colors. Tumble dry low. Do not bleach. Iron on low heat if needed.
    </p>
  </div>
</div>

<script>
function openSizeGuidePopup() {
  document.getElementById('sizeGuidePopup').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeSizeGuidePopup() {
  document.getElementById('sizeGuidePopup').classList.remove('active');
  document.body.style.overflow = '';
}

// Close modal on outside click
document.getElementById('sizeGuidePopup').addEventListener('click', function(e) {
  if (e.target === this) {
    closeSizeGuidePopup();
  }
});

// Close on Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    closeSizeGuidePopup();
  }
});
</script>
