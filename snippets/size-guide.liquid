<!-- T-P009: Size Guide Popup Content -->
<style>
  .size-guide-popup {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.6);
    z-index: 2000;
    align-items: center;
    justify-content: center;
  }

  .size-guide-popup.active {
    display: flex;
  }

  .size-guide-popup__content {
    background: white;
    border-radius: 16px;
    max-width: 600px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    padding: 30px;
    position: relative;
    animation: modalSlideIn 0.3s ease;
  }

  @keyframes modalSlideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .size-guide-popup__close {
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #666;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.2s ease;
  }

  .size-guide-popup__close:hover {
    background: #f5f5f5;
  }

  .size-guide-popup h2 {
    margin: 0 0 10px;
    color: #333;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .size-guide-popup__intro {
    color: #666;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .size-guide-popup__table-wrapper {
    overflow-x: auto;
  }

  .size-guide-popup table {
    width: 100%;
    border-collapse: collapse;
    margin: 15px 0;
  }

  .size-guide-popup th,
  .size-guide-popup td {
    padding: 12px;
    text-align: center;
    border: 1px solid #eee;
  }

  .size-guide-popup th {
    background: linear-gradient(135deg, #ff6b9d, #e84a7f);
    color: white;
    font-weight: 600;
  }

  .size-guide-popup td {
    color: #666;
  }

  .size-guide-popup tr:nth-child(even) td {
    background: #fafafa;
  }

  .size-guide-popup__note {
    font-size: 0.85rem;
    color: #888;
    margin-top: 20px;
    padding: 15px;
    background: #f8f8f8;
    border-radius: 8px;
    line-height: 1.5;
  }

  .size-guide-popup__tip {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 15px;
    padding: 12px;
    background: #fff5f8;
    border-radius: 8px;
    border-left: 3px solid #ff6b9d;
  }

  .size-guide-popup__tip svg {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: #e84a7f;
  }

  .size-guide-popup__tip p {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
  }

  /* Age Group Guide */
  .size-guide-age-guide {
    margin-top: 25px;
    padding-top: 20px;
    border-top: 1px solid #eee;
  }

  .size-guide-age-guide h3 {
    margin: 0 0 15px;
    color: #333;
    font-size: 1.1rem;
  }

  .age-group-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 10px;
  }

  .age-group-item {
    text-align: center;
    padding: 10px;
    background: #f5f5f5;
    border-radius: 8px;
  }

  .age-group-item span {
    display: block;
    font-weight: 600;
    color: #333;
  }

  .age-group-item small {
    font-size: 0.8rem;
    color: #888;
  }
</style>

<!-- Size Guide Trigger Button -->
<button class="size-guide-trigger" onclick="openSizeGuidePopup()">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
    <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"/>
  </svg>
  Size Guide
</button>

<!-- Size Guide Modal -->
