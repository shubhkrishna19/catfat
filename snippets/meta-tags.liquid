{% comment %}
  Renders OG + Twitter meta tags with brand-safe fallbacks.
  - og:image falls back to settings.logo or settings.share_image
  - og:type switches to 'product' on product pages
  - twitter:card defaults to summary_large_image
  - https:// scheme enforced
{% endcomment %}

{%- liquid
  assign og_title = page_title
  if og_title == blank
    assign og_title = shop.name
  endif

  assign og_description = page_description
  if og_description == blank
    assign og_description = "India's favourite kids lunch boxes, bottles, and lunchware — BPA free, microwave safe, leak proof."
  endif

  assign og_image_source = page_image
  if og_image_source == blank
    assign og_image_source = settings.share_image
  endif
  if og_image_source == blank
    assign og_image_source = settings.logo
  endif

  assign og_type = 'website'
  if template contains 'product'
    assign og_type = 'product'
  elsif template contains 'article'
    assign og_type = 'article'
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:locale" content="en_IN">

{%- if og_image_source != blank -%}
  <meta property="og:image" content="https:{{ og_image_source | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ og_image_source | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ og_title | escape }}">
{%- endif -%}

{%- if template contains 'product' and product != blank -%}
  <meta property="product:brand" content="{{ shop.name }}">
  <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
  <meta property="product:condition" content="new">
  <meta property="product:price:amount" content="{{ product.price | money_without_currency | replace: ',', '' }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image_source != blank -%}
  <meta name="twitter:image" content="https:{{ og_image_source | image_url: width: 1200 }}">
{%- endif -%}
