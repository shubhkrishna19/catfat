{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign price = current_variant.price | default: product.price_min
  assign compare_at_price = current_variant.compare_at_price | default: product.compare_at_price_max
  if compare_at_price < price
    assign compare_at_price = product.compare_at_price_max
  endif

  assign primary_media = current_variant.featured_media | default: product.featured_media
  assign secondary_media = blank
  for media in product.media
    if media.media_type == 'image' and primary_media != blank and media.id != primary_media.id
      assign secondary_media = media
      break
    elsif media.media_type == 'image' and primary_media == blank and secondary_media == blank
      assign secondary_media = media
    endif
  endfor

  assign title_text = product.title | downcase
  assign product_text = product.title | append: ' ' | append: product.description | strip_html | downcase
  assign theme_count = 0
  assign color_count = 0
  assign style_count = 0
  assign has_name_engraving = false

  if product_text contains 'engraving' or product_text contains 'personalised' or product_text contains 'personalized'
    assign has_name_engraving = true
  endif

  for option in product.options_with_values
    assign option_name = option.name | strip | downcase
    if option_name contains 'theme'
      assign theme_count = option.values.size
    elsif option_name contains 'color' or option_name contains 'colour'
      assign color_count = option.values.size
    elsif option_name contains 'style' or option_name contains 'personal' or option_name contains 'engraving'
      assign style_count = option.values.size
    endif

  endfor

  assign eyebrow_text = 'Everyday pick'
  if theme_count > 0
    assign eyebrow_text = 'Kids themes'
  elsif product_text contains 'vacuum' or product_text contains 'insulated'
    assign eyebrow_text = 'Insulated'
  elsif product_text contains 'microwave'
    assign eyebrow_text = 'Microwave safe'
  elsif product_text contains 'stainless'
    assign eyebrow_text = 'Stainless steel'
  endif

  assign benefit_title = 'Daily-use lunchware for school and travel.'
  if product_text contains 'microwave'
    assign benefit_title = 'Microwave-ready for easier lunch prep.'
  elsif product_text contains 'vacuum' or product_text contains 'insulated'
    assign benefit_title = 'Insulated for longer-lasting freshness.'
  elsif product_text contains 'leak' or product_text contains 'spill'
    assign benefit_title = 'Leak-resistant for cleaner bag carry.'
  elsif product_text contains 'stainless'
    assign benefit_title = 'Stainless steel for everyday durability.'
  elsif product_text contains 'spoon'
    assign benefit_title = 'Built-in spoon for easier meal breaks.'
  elsif product_text contains 'cutlery'
    assign benefit_title = 'Compact cutlery for school and travel.'
  endif

  assign meta_primary = blank
  assign meta_secondary = blank
  if theme_count > 0
    assign meta_primary = theme_count | append: ' theme'
    if theme_count != 1
      assign meta_primary = meta_primary | append: 's'
    endif
  elsif color_count > 0
    assign meta_primary = color_count | append: ' color'
    if color_count != 1
      assign meta_primary = meta_primary | append: 's'
    endif
  elsif style_count > 1
    assign meta_primary = style_count | append: ' style'
    if style_count != 1
      assign meta_primary = meta_primary | append: 's'
    endif
  elsif product.variants.size > 1
    assign meta_primary = product.variants.size | append: ' option'
    if product.variants.size != 1
      assign meta_primary = meta_primary | append: 's'
    endif
  endif

  if product_text contains 'vacuum' or product_text contains 'insulated'
    assign meta_secondary = 'Hot and cold ready'
  elsif product_text contains 'microwave'
    assign meta_secondary = 'Microwave safe'
  elsif product_text contains 'stainless'
    assign meta_secondary = 'Stainless steel'
  elsif product_text contains 'leak' or product_text contains 'spill'
    assign meta_secondary = 'Leak resistant'
  elsif product_text contains 'spoon'
    assign meta_secondary = 'Built-in spoon'
  endif

  if meta_primary == blank and style_count > 1
    assign meta_primary = style_count | append: ' style'
    if style_count != 1
      assign meta_primary = meta_primary | append: 's'
    endif
  endif

  assign support_text = 'See colors, sizes, and product details.'
  if product.available == false
    assign support_text = 'Currently unavailable online.'
  elsif title_text contains 'kuromi' and title_text contains 'panda'
    assign support_text = 'Character-led gifting favourite.'
  elsif title_text contains 'kuromi'
    assign support_text = 'Bold character look kids notice fast.'
  elsif title_text contains 'panda'
    assign support_text = 'Playful panda styling for daily carry.'
  elsif title_text contains 'kawaii'
    assign support_text = 'Cute daily-use pick with gifting appeal.'
  elsif title_text contains 'cutlery' or title_text contains 'fork' or title_text contains 'chopsticks'
    assign support_text = 'Easy add-on for school and travel meals.'
  elsif title_text contains 'mini' and title_text contains 'bento'
    assign support_text = 'Compact fit for smaller appetites.'
  elsif title_text contains 'tri bite' or product_text contains '3-compartment' or product_text contains '3 compartment' or product_text contains 'three compartment'
    assign support_text = 'Three sections for tidier lunch packing.'
  elsif title_text contains 'bento'
    assign support_text = 'Organised compartments for cleaner packing.'
  elsif title_text contains 'leak-lock' or product_text contains 'leakproof' or product_text contains 'leak resistant' or product_text contains 'leak-resistant'
    assign support_text = 'Built for calmer bags and cleaner mornings.'
  elsif title_text contains 'thermos' and title_text contains 'spoon'
    assign support_text = 'Warm-meal support with spoon convenience.'
  elsif title_text contains 'pot'
    assign support_text = 'Comfort-meal format with easier carrying.'
  elsif title_text contains 'vacuum' or title_text contains 'insulated'
    assign support_text = 'Keeps drinks or meals ready for longer.'
  elsif title_text contains 'microwave'
    assign support_text = 'Quick reheat convenience for school days.'
  elsif title_text contains 'stainless'
    assign support_text = 'Steel build made for repeated daily use.'
  elsif has_name_engraving
    assign support_text = 'Personalised gifting option available.'
  endif

  assign savings_amount = 0
  assign savings_percent = 0
  assign savings_amount_money = blank
  if compare_at_price > price and compare_at_price != blank
    assign savings_amount = compare_at_price | minus: price
    assign savings_percent = savings_amount | times: 100 | divided_by: compare_at_price
    assign savings_amount_money = savings_amount | money
  endif

  assign action_label = 'Add to cart'
  if product.available == false
    assign action_label = 'View product'
  elsif product.variants.size > 1
    assign action_label = 'View options'
  endif

  assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: product.id
-%}

<article class="market-card{% unless product.available %} is-sold-out{% endunless %}">
  <a href="{{ product.url }}" class="market-card__media">
    <div class="market-card__badge-group">
      {%- if savings_percent > 0 -%}
        <span class="market-card__badge">Save {{ savings_percent }}%</span>
      {%- endif -%}
      {%- if has_name_engraving -%}
        <span class="market-card__badge market-card__badge--light">Name engraving</span>
      {%- endif -%}
    </div>

    <div class="market-card__canvas">
      {%- if primary_media != blank -%}
        {{
          primary_media
          | image_url: width: 900
          | image_tag:
            class: 'market-card__image market-card__image--primary',
            widths: '320, 480, 640, 900',
            loading: 'lazy',
            alt: product.title
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'market-card__image market-card__image--primary' }}
      {%- endif -%}

      {%- if secondary_media != blank -%}
        {{
          secondary_media
          | image_url: width: 900
          | image_tag:
            class: 'market-card__image market-card__image--secondary',
            widths: '320, 480, 640, 900',
            loading: 'lazy',
            alt: product.title
        }}
      {%- endif -%}
    </div>
  </a>

  <div class="market-card__body">
    <div class="market-card__topline">
      <span class="market-card__eyebrow">{{ eyebrow_text }}</span>
    </div>

    <a href="{{ product.url }}" class="market-card__title">{{ product.title | escape }}</a>
    <p class="market-card__subtitle">{{ benefit_title }}</p>

    <div class="market-card__meta{% if meta_primary == blank and meta_secondary == blank %} market-card__meta--empty{% endif %}">
      {%- if meta_primary != blank -%}
        <span class="market-card__meta-item">{{ meta_primary }}</span>
      {%- endif -%}
      {%- if meta_secondary != blank -%}
        <span class="market-card__meta-item">{{ meta_secondary }}</span>
      {%- endif -%}
    </div>

    <div class="market-card__price-panel{% unless savings_percent > 0 %} market-card__price-panel--simple{% endunless %}">
      <div class="market-card__price-stack">
        <span class="market-card__price">
          {%- if product.price_varies -%}
            {{ product.price_min | money }}
          {%- else -%}
            {{ price | money }}
          {%- endif -%}
        </span>
        {%- if compare_at_price > price and compare_at_price != blank -%}
          <span class="market-card__compare">{{ compare_at_price | money }}</span>
        {%- endif -%}
      </div>

      {%- if savings_percent > 0 -%}
        <div class="market-card__deal">
          <strong>{{ savings_percent }}% off</strong>
          <span>Save {{ savings_amount_money }}</span>
        </div>
      {%- endif -%}
    </div>

    <p class="market-card__proof">{{ support_text }}</p>

    {%- if product.available and product.variants.size == 1 -%}
      <product-form class="market-card__form">
        {%- form 'product', product, id: product_form_id, class: 'market-card__form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <button type="submit" name="add" class="market-card__action">
            {{ action_label }}
          </button>
        {%- endform -%}
      </product-form>
    {%- else -%}
      <a href="{{ product.url }}" class="market-card__action{% unless product.available %} market-card__action--secondary{% endunless %}">
        {{ action_label }}
      </a>
    {%- endif -%}
  </div>
</article>
