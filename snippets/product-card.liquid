{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign price = current_variant.price | default: product.price_min
  assign compare_at_price = current_variant.compare_at_price | default: product.compare_at_price_max

  if compare_at_price < price
    assign compare_at_price = product.compare_at_price_max
  endif

  assign primary_media = current_variant.featured_media | default: product.featured_media
  assign secondary_media = product.media[1]
  assign show_sale_badge = false

  if compare_at_price > price and compare_at_price != blank
    assign show_sale_badge = true
  endif

  assign discount_pct = 0
  if show_sale_badge and compare_at_price > 0
    assign discount_pct = compare_at_price | minus: price | times: 100 | divided_by: compare_at_price
  endif

  assign is_multi_variant = false
  if product.variants.size > 1
    assign is_multi_variant = true
  endif

  assign action_label = 'Add to Cart'
  unless product.available
    assign action_label = 'Sold out'
  endunless
  if is_multi_variant and product.available
    assign action_label = 'View Options'
  endif

  assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: product.id

  # Optional Instagram reel (set product metafield catfat.reel_url to an MP4 URL
  # or a Shopify-hosted video file). If a file metafield, render its sources.
  assign reel_url = product.metafields.catfat.reel_url
  assign reel_video = product.metafields.catfat.reel_video
  assign reel_poster = product.metafields.catfat.reel_poster
  assign has_reel = false
  if reel_url != blank or reel_video != blank
    assign has_reel = true
  endif
-%}

<article
  class="market-card{% unless product.available %} is-sold-out{% endunless %}{% if is_multi_variant %} is-multi-variant{% endif %}{% if has_reel %} has-reel{% endif %}"
  data-card-depth
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  {% if has_reel %}data-has-reel="true"{% endif %}
>
  <a href="{{ product.url }}" class="market-card__media">
    <div class="market-card__badge-group">
      {%- if show_sale_badge and discount_pct > 0 -%}
        <span class="market-card__badge">-{{ discount_pct }}%</span>
      {%- elsif show_sale_badge -%}
        <span class="market-card__badge">Sale</span>
      {%- endif -%}
      {%- if product.tags contains 'new' or product.tags contains 'New' -%}
        <span class="market-card__badge market-card__badge--new">New</span>
      {%- endif -%}
    </div>

    <div class="market-card__canvas">
      {%- if primary_media != blank -%}
        {{
          primary_media
          | image_url: width: 900
          | image_tag:
            class: 'market-card__image market-card__image--primary',
            widths: '320, 480, 640, 900',
            loading: 'lazy',
            alt: product.title
        }}
        {%- if secondary_media != blank -%}
          {{
            secondary_media
            | image_url: width: 900
            | image_tag:
              class: 'market-card__image market-card__image--secondary',
              widths: '320, 480, 640, 900',
              loading: 'lazy',
              alt: product.title
          }}
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'market-card__image market-card__image--primary' }}
      {%- endif -%}

      {%- if has_reel -%}
        <video
          class="market-card__reel"
          muted
          loop
          playsinline
          preload="none"
          {% if reel_poster != blank %}poster="{{ reel_poster | image_url: width: 720 }}"{% endif %}
          aria-hidden="true"
        >
          {%- if reel_video != blank -%}
            {%- for source in reel_video.value.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          {%- elsif reel_url != blank -%}
            <source src="{{ reel_url }}" type="video/mp4">
          {%- endif -%}
        </video>
        <span class="market-card__reel-badge" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M8 5v14l11-7z"/></svg>
          REEL
        </span>
      {%- endif -%}
    </div>
  </a>

  <div class="market-card__body">
    <a href="{{ product.url }}" class="market-card__title">{{ product.title | escape }}</a>

    <div class="market-card__price-panel">
      <span class="market-card__price">
        {%- if product.price_varies -%}
          From {{ product.price_min | money }}
        {%- else -%}
          {{ price | money }}
        {%- endif -%}
      </span>
      {%- if show_sale_badge -%}
        <s class="market-card__compare">{{ compare_at_price | money }}</s>
      {%- endif -%}
    </div>

    <div class="market-card__cta">
      {%- if product.available -%}
        {%- if is_multi_variant -%}
          <a href="{{ product.url }}" class="market-card__action">
            {{ action_label }}
          </a>
        {%- else -%}
          <product-form class="market-card__form">
            {%- form 'product', product, id: product_form_id, class: 'market-card__form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
              <button
                type="submit"
                name="add"
                class="market-card__action"
                aria-label="Add {{ product.title | escape }} to cart"
              >
                {{ action_label }}
              </button>
            {%- endform -%}
          </product-form>
        {%- endif -%}
      {%- else -%}
        <button type="button" class="market-card__action market-card__action--disabled" disabled aria-disabled="true">
          {{ action_label }}
        </button>
      {%- endif -%}
    </div>
  </div>
</article>
