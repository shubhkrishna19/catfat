{% comment %}
  Pagination Snippet
  Uses the Catfat marketplace color system.
{% endcomment %}
{%- if paginate.pages > 1 -%}
  <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination' | t }}">
    <ul class="pagination__list" role="list">
      {%- if paginate.previous -%}
        <li>
          <a href="{{ paginate.previous.url }}" class="pagination__item pagination__item--prev" aria-label="{{ 'general.pagination.previous' | t }}">
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 19" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" fill="currentColor"/>
            </svg>
            <span>Prev</span>
          </a>
        </li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <li>
            <a href="{{ part.url }}" class="pagination__item" aria-label="{{ part.title }}">{{ part.title }}</a>
          </li>
        {%- else -%}
          {%- if part.title == paginate.current_page -%}
            <li>
              <span class="pagination__item pagination__item--current" aria-current="page" aria-label="{{ part.title }}">{{ part.title }}</span>
            </li>
          {%- else -%}
            <li>
              <span class="pagination__item">{{ part.title }}</span>
            </li>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.next -%}
        <li>
          <a href="{{ paginate.next.url }}" class="pagination__item pagination__item--next" aria-label="{{ 'general.pagination.next' | t }}">
            <span>Next</span>
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 19" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" fill="currentColor"/>
            </svg>
          </a>
        </li>
      {%- endif -%}
    </ul>
  </nav>
{%- endif -%}

<style>
  .pagination {
    display: flex;
    justify-content: center;
    padding: 44px 0 18px;
  }

  .pagination__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pagination__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-width: 54px;
    min-height: 54px;
    padding: 0 18px;
    font-size: 1.55rem;
    font-weight: 900;
    color: #311d2a;
    text-decoration: none;
    border-radius: 14px;
    background: #ffffff;
    border: 1px solid rgba(232, 74, 127, 0.14);
    box-shadow: 0 14px 24px rgba(108, 89, 100, 0.1);
    transition: transform 0.22s ease, background 0.22s ease, color 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .pagination__item:hover:not(.pagination__item--current) {
    transform: translateY(-2px);
    background: #fff5fa;
    color: #d73d72;
    border-color: rgba(232, 74, 127, 0.24);
    box-shadow: 0 18px 30px rgba(232, 74, 127, 0.14);
  }

  .pagination__item--current {
    background: linear-gradient(135deg, #ff6b9d 0%, #e84a7f 58%, #ff8e53 100%);
    color: #fff;
    box-shadow: 0 18px 28px rgba(232, 74, 127, 0.24);
  }

  .pagination__item svg {
    width: 18px;
    height: 18px;
  }

  .pagination__item--prev,
  .pagination__item--next {
    min-width: 84px;
  }

  @media screen and (max-width: 749px) {
    .pagination {
      padding-top: 34px;
    }

    .pagination__list {
      gap: 10px;
    }

    .pagination__item {
      min-width: 48px;
      min-height: 48px;
      padding: 0 14px;
      font-size: 1.4rem;
      border-radius: 12px;
    }

    .pagination__item--prev,
    .pagination__item--next {
      min-width: 74px;
    }
  }
</style>
