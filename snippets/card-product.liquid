{% comment %} Product Card Snippet - Playful Style {% endcomment %}

<style>
.product-card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 10px 25px rgba(255, 107, 157, 0.2);
  border-color: #ff6b9d;
}

.product-card__image {
  position: relative;
  aspect-ratio: 1;
  background: linear-gradient(135deg, #fff5f8 0%, #ffeef3 100%);
  overflow: hidden;
}

.product-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.product-card:hover .product-card__image img {
  transform: scale(1.05);
}

.product-card__badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  color: #fff;
  padding: 5px 12px;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  border-radius: 20px;
  z-index: 2;
}

.product-card__badge.sale {
  background: linear-gradient(135deg, #ffd93d, #ffb300);
  color: #333;
}

.product-card__content { padding: 12px; }

.product-card__vendor {
  font-size: 0.65rem;
  color: #ff6b9d;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
  margin-bottom: 4px;
}

.product-card__title {
  font-size: 0.9rem;
  font-weight: 600;
  color: #333;
  margin-bottom: 6px;
  text-decoration: none;
  display: block;
  line-height: 1.3;
}

.product-card__title:hover { color: #ff6b9d; }

.product-card__price {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.product-card__price-current {
  font-size: 1rem;
  font-weight: 700;
  color: #ff6b9d;
}

.product-card__price-compare {
  font-size: 0.8rem;
  color: #999;
  text-decoration: line-through;
}

.product-card__btn {
  width: 100%;
  padding: 10px;
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.8rem;
  cursor: pointer;
  transition: all 0.3s ease;
}

.product-card__btn:hover {
  transform: scale(1.02);
  box-shadow: 0 5px 15px rgba(255, 107, 157, 0.4);
}
</style>

<div class="product-card">
  <a href="{{ product.url }}" class="product-card__image">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}" 
           alt="{{ product.title | escape }}"
           loading="lazy">
    {%- else -%}
      <img src="https://placehold.co/400x400/ff6b9d/ffffff?text={{ product.title | url_encode }}" 
           alt="{{ product.title | escape }}">
    {%- endif -%}
    
    {%- if product.tags contains 'new' -%}
      <span class="product-card__badge">New</span>
    {%- elsif product.compare_at_price > product.price -%}
      <span class="product-card__badge sale">Sale</span>
    {%- endif -%}
  </a>
  
  <div class="product-card__content">
    {%- if product.vendor != blank -%}
      <div class="product-card__vendor">{{ product.vendor }}</div>
    {%- endif -%}
    
    <a href="{{ product.url }}" class="product-card__title">{{ product.title }}</a>
    
    <div class="product-card__price">
      <span class="product-card__price-current">
        {%- if product.price_varies -%}
          From {{ product.price_min | money }}
        {%- else -%}
          {{ product.price | money }}
        {%- endif -%}
      </span>
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__price-compare">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
    
    <button class="product-card__btn" onclick="addToCart({{ product.selected_or_first_available_variant.id }})">
      Add to Cart
    </button>
  </div>
</div>

<script>
function addToCart(variantId) {
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
  })
  .then(response => response.json())
  .then(data => { window.location.href = '/cart'; })
  .catch(error => { console.error('Error:', error); alert('Failed to add to cart.'); });
}
</script>
