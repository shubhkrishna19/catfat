{%- assign free_shipping_threshold = 49900 -%}

<style>
  .cart-page {
    padding: clamp(3.2rem, 4.4vw, 5.2rem) 0 clamp(4.8rem, 6vw, 6.4rem);
    max-width: none;
    margin: 0 auto;
  }

  .cart-page__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    margin-bottom: clamp(2.4rem, 3vw, 3.2rem);
  }

  .cart-page__title {
    margin: 0;
    color: var(--catfat-copy-strong);
    font-size: clamp(3rem, 2.7rem + 0.7vw, 4rem);
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .cart-page__continue {
    color: var(--catfat-copy-body);
    text-decoration: none;
    font-size: 1.35rem;
    font-weight: 700;
    transition: color 0.22s ease;
  }

  .cart-page__continue:hover,
  .cart-page__continue:focus-visible {
    color: var(--catfat-brand-purple);
  }

  .cart-page__empty {
    display: grid;
    gap: 1.2rem;
    justify-items: center;
    padding: clamp(4rem, 6vw, 5.6rem) clamp(2rem, 4vw, 3rem);
    border-radius: 1.8rem;
    border: 1px solid var(--catfat-card-border);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 36px rgba(var(--catfat-brand-purple-rgb), 0.06);
    text-align: center;
  }

  .cart-page__empty p {
    margin: 0;
    color: var(--catfat-copy-body);
    font-size: 1.45rem;
    line-height: 1.6;
  }

  .cart-page__empty .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.8rem;
    padding: 0 2rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--catfat-brand-purple-soft), var(--catfat-brand-purple) 58%, var(--catfat-brand-purple-deep));
    color: #fff;
    font-size: 1.35rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 14px 28px rgba(var(--catfat-brand-purple-rgb), 0.18);
  }

  .cart-page__shipping-progress {
    margin-bottom: 2.4rem;
    padding: 1.6rem 1.8rem;
    border: 1px solid var(--catfat-card-border);
    border-radius: 1.6rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 28px rgba(var(--catfat-brand-purple-rgb), 0.06);
  }

  .shipping-progress {
    display: grid;
    gap: 1rem;
  }

  .shipping-progress__text {
    margin: 0;
    color: var(--catfat-copy-strong);
    font-size: 1.35rem;
    line-height: 1.5;
    font-weight: 600;
  }

  .shipping-progress__text strong {
    color: var(--catfat-brand-purple);
  }

  .shipping-progress__bar {
    height: 0.8rem;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(var(--catfat-brand-purple-rgb), 0.1);
  }

  .shipping-progress__fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--catfat-brand-purple-soft), var(--catfat-brand-purple));
    transition: width 0.3s ease;
  }

  .shipping-progress__message {
    margin: 0;
    color: #1e8757;
    font-size: 1.25rem;
    line-height: 1.4;
    font-weight: 600;
  }

  .cart-form {
    display: block;
  }

  .cart-page__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(30rem, 36rem);
    gap: clamp(3.2rem, 3.8vw, 4rem);
    align-items: start;
  }

  .cart-page__main {
    display: grid;
    gap: 2.4rem;
  }

  .cart-page__items-shell {
    padding: 0 2rem;
    border: 1px solid var(--catfat-card-border);
    border-radius: 1.8rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 28px rgba(var(--catfat-brand-purple-rgb), 0.06);
  }

  .cart-page__items {
    display: grid;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 8.8rem minmax(0, 1fr) auto;
    gap: 1.6rem;
    align-items: center;
    padding: 1.8rem 0;
  }

  .cart-item + .cart-item {
    border-top: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
  }

  .cart-item__media {
    width: 8.8rem;
    height: 8.8rem;
    border-radius: 1.2rem;
    overflow: hidden;
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.06);
  }

  .cart-item__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__details {
    display: grid;
    gap: 0.5rem;
    min-width: 0;
  }

  .cart-item__name,
  .cart-item__title {
    color: var(--catfat-copy-strong);
    font-size: 1.55rem;
    line-height: 1.35;
    font-weight: 700;
    text-decoration: none;
  }

  .cart-item__options {
    color: var(--catfat-copy-body);
    font-size: 1.28rem;
    line-height: 1.45;
    font-weight: 500;
  }

  .cart-item__stock {
    color: #1e8757;
    font-size: 1.18rem;
    line-height: 1.35;
    font-weight: 600;
  }

  .cart-item__stock--unavailable {
    color: #d14a4a;
  }

  .cart-item__controls {
    display: grid;
    justify-items: end;
    gap: 1rem;
    min-width: 13rem;
  }

  .cart-item__price {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.8rem;
    flex-wrap: wrap;
    color: var(--catfat-brand-purple);
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 700;
  }

  .cart-item__price .price--regular {
    color: var(--catfat-copy-muted);
    font-size: 1.25rem;
    font-weight: 500;
    text-decoration: line-through;
  }

  .cart-item__quantity {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .quantity {
    display: inline-flex;
    align-items: center;
    min-height: 4.2rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.1);
    border-radius: 999px;
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.06);
    overflow: hidden;
  }

  .quantity__button {
    width: 3.8rem;
    height: 4.2rem;
    border: 0;
    background: transparent;
    color: var(--catfat-copy-strong);
    font-size: 1.6rem;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .quantity__button:hover,
  .quantity__button:focus-visible {
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.14);
    color: var(--catfat-brand-purple);
  }

  .quantity__input {
    width: 4.8rem;
    height: 4.2rem;
    border: 0;
    background: transparent;
    color: var(--catfat-copy-strong);
    text-align: center;
    font-size: 1.35rem;
    font-weight: 700;
    appearance: textfield;
  }

  .quantity__input::-webkit-outer-spin-button,
  .quantity__input::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .cart-remove__button {
    color: var(--catfat-copy-muted);
    font-size: 1.22rem;
    line-height: 1.2;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cart-remove__button:hover,
  .cart-remove__button:focus-visible {
    color: #d14a4a;
  }

  .cart-page__utility {
    display: grid;
    gap: 1.6rem;
  }

  .cart-page__discount-section,
  .cart-page__note-card,
  .cart-page__totals {
    border: 1px solid var(--catfat-card-border);
    border-radius: 1.8rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 28px rgba(var(--catfat-brand-purple-rgb), 0.06);
  }

  .cart-page__discount-section,
  .cart-page__note-card {
    padding: 1.6rem 1.8rem;
  }

  .discount-section__title,
  .cart-note__label {
    display: block;
    margin: 0 0 1rem;
    color: var(--catfat-copy-strong);
    font-size: 1.35rem;
    line-height: 1.35;
    font-weight: 700;
  }

  .discount-form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
  }

  .discount-form__input,
  .cart-note__input {
    width: 100%;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.1);
    border-radius: 1.2rem;
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.05);
    color: var(--catfat-copy-strong);
    font-size: 1.35rem;
    line-height: 1.45;
    font-weight: 500;
  }

  .discount-form__input {
    min-height: 4.6rem;
    padding: 0 1.4rem;
  }

  .discount-form__input:focus,
  .cart-note__input:focus {
    outline: none;
    border-color: rgba(var(--catfat-brand-purple-rgb), 0.2);
  }

  .discount-form__button {
    min-height: 4.6rem;
    padding: 0 1.8rem;
    border: 0;
    border-radius: 1.2rem;
    background: linear-gradient(135deg, var(--catfat-brand-purple-soft), var(--catfat-brand-purple) 58%, var(--catfat-brand-purple-deep));
    color: #fff;
    font-size: 1.3rem;
    font-weight: 700;
    cursor: pointer;
  }

  .discount-messages {
    display: grid;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .discount-error,
  .discount-success {
    display: none;
    padding: 0.9rem 1.1rem;
    border-radius: 1rem;
    font-size: 1.2rem;
    line-height: 1.4;
    font-weight: 600;
  }

  .discount-error {
    color: #d14a4a;
    background: rgba(209, 74, 74, 0.08);
  }

  .discount-success {
    color: #1e8757;
    background: rgba(30, 135, 87, 0.08);
  }

  .discount-error.show,
  .discount-success.show {
    display: block;
  }

  .applied-discounts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .applied-discount {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 3.4rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: rgba(30, 135, 87, 0.08);
    color: #1e8757;
    font-size: 1.2rem;
    line-height: 1.2;
    font-weight: 600;
  }

  .cart-note__input {
    min-height: 7.6rem;
    padding: 1.2rem 1.4rem;
    resize: vertical;
  }

  .cart-page__summary-column {
    min-width: 0;
  }

  .cart-page__summary-sticky {
    position: sticky;
    top: 10.8rem;
  }

  .cart-page__totals {
    padding: 2rem;
  }

  .cart-subtotals {
    display: grid;
    gap: 1rem;
  }

  .cart-subtotals__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--catfat-copy-strong);
    font-size: 1.4rem;
    line-height: 1.45;
    font-weight: 600;
  }

  .cart-subtotals__row.cart-subtotals__total {
    margin-top: 0.4rem;
    padding-top: 1.4rem;
    border-top: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.1);
    color: var(--catfat-brand-purple);
    font-size: 1.7rem;
    font-weight: 800;
  }

  .cart-subtotals__shipping {
    display: grid;
    gap: 0.6rem;
    margin-top: 0.2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
  }

  .cart-subtotals__shipping p {
    margin: 0;
    color: var(--catfat-copy-body);
    font-size: 1.25rem;
    line-height: 1.5;
    font-weight: 500;
  }

  .checkout-payment-icons,
  .checkout-trust-signals {
    margin-top: 1.6rem;
    padding: 1.3rem 1.4rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
    border-radius: 1.4rem;
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.05);
  }

  .payment-icons-label {
    display: block;
    margin-bottom: 0.8rem;
    color: var(--catfat-copy-muted);
    font-size: 1.1rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .payment-icons-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .payment-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.2rem;
    padding: 0.6rem 0.9rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
    border-radius: 999px;
    background: #fff;
    color: var(--catfat-copy-strong);
    font-size: 1.05rem;
    line-height: 1.2;
    font-weight: 700;
  }

  .checkout-trust-signals {
    display: grid;
    gap: 0.8rem;
  }

  .trust-signal {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--catfat-copy-body);
    font-size: 1.2rem;
    line-height: 1.45;
    font-weight: 600;
  }

  .trust-signal svg {
    flex: 0 0 1.8rem;
    color: #1e8757;
  }

  .cart-checkout__button {
    width: 100%;
    min-height: 5.2rem;
    margin-top: 1.8rem;
    border: 0;
    border-radius: 1.3rem;
    background: linear-gradient(135deg, var(--catfat-brand-purple-soft), var(--catfat-brand-purple) 58%, var(--catfat-brand-purple-deep));
    color: #fff;
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 16px 30px rgba(var(--catfat-brand-purple-rgb), 0.2);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .cart-checkout__button:hover,
  .cart-checkout__button:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 20px 34px rgba(var(--catfat-brand-purple-rgb), 0.24);
  }

  .continue-shopping__link {
    display: inline-flex;
    justify-content: center;
    width: 100%;
    margin-top: 1.2rem;
    color: var(--catfat-copy-body);
    font-size: 1.25rem;
    line-height: 1.4;
    font-weight: 600;
    text-decoration: none;
  }

  @media (max-width: 989px) {
    .cart-page__layout {
      grid-template-columns: 1fr;
      gap: 2.4rem;
    }

    .cart-page__summary-sticky {
      position: static;
    }
  }

  @media (max-width: 749px) {
    .cart-page {
      padding: 2.4rem 0 4rem;
    }

    .cart-page__header {
      align-items: flex-start;
      flex-direction: column;
      margin-bottom: 2rem;
    }

    .cart-page__shipping-progress {
      margin-bottom: 2rem;
      padding: 1.4rem;
    }

    .cart-page__items-shell {
      padding: 0 1.4rem;
    }

    .cart-item {
      grid-template-columns: 7.2rem minmax(0, 1fr);
      gap: 1.2rem;
    }

    .cart-item__media {
      width: 7.2rem;
      height: 7.2rem;
    }

    .cart-item__controls {
      grid-column: 2;
      justify-items: start;
      min-width: 0;
    }

    .cart-item__price {
      justify-content: flex-start;
    }

    .cart-page__discount-section,
    .cart-page__note-card,
    .cart-page__totals {
      padding: 1.4rem;
    }

    .discount-form {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="cart-page page-width">
  <div class="cart-page__header">
    <h1 class="cart-page__title">Shopping Cart</h1>
    <a href="{{ routes.collections_url }}" class="cart-page__continue">Continue shopping</a>
  </div>

  {%- if cart == empty -%}
    <div class="cart-page__empty">
      <p>Your cart is empty.</p>
      <p>Looks like you haven’t added anything yet.</p>
      <a href="{{ routes.collections_url }}" class="button">Start shopping</a>
    </div>
  {%- else -%}
    <div class="cart-page__shipping-progress">
      <div class="shipping-progress">
        <p class="shipping-progress__text">
          {%- if cart.total_price < free_shipping_threshold -%}
            Add <strong>{{ free_shipping_threshold | minus: cart.total_price | money }}</strong> more for <strong>FREE shipping</strong>
          {%- else -%}
            Free shipping unlocked. <strong>You’re all set.</strong>
          {%- endif -%}
        </p>
        <div class="shipping-progress__bar">
          <div class="shipping-progress__fill" style="width: {{ cart.total_price | times: 100 | divided_by: free_shipping_threshold | at_most: 100 }}%"></div>
        </div>
        {%- if cart.total_price >= free_shipping_threshold -%}
          <p class="shipping-progress__message">Free shipping applied to your order.</p>
        {%- endif -%}
      </div>
    </div>

    <form action="{{ routes.cart_url }}" id="cart-form" class="cart-form" method="post">
      <div class="cart-page__layout">
        <div class="cart-page__main">
          <div class="cart-page__items-shell">
            <div class="cart-page__items">
              {%- for item in cart.items -%}
                <div class="cart-item">
                  <div class="cart-item__media">
                    <a href="{{ item.url }}">
                      {%- if item.image != blank -%}
                        {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item.title }}
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </a>
                  </div>

                  <div class="cart-item__details">
                    <a href="{{ item.url }}" class="cart-item__name cart-item__title">{{ item.product.title }}</a>

                    {%- if item.variant.title != 'Default Title' -%}
                      <div class="cart-item__options">{{ item.variant.title }}</div>
                    {%- endif -%}

                    {%- if item.variant.available -%}
                      <div class="cart-item__stock">In stock</div>
                    {%- else -%}
                      <div class="cart-item__stock cart-item__stock--unavailable">Out of stock</div>
                    {%- endif -%}
                  </div>

                  <div class="cart-item__controls">
                    <div class="cart-item__price">
                      <span class="price">{{ item.line_price | money }}</span>
                      {%- if item.original_line_price != item.line_price -%}
                        <span class="price price--regular">{{ item.original_line_price | money }}</span>
                      {%- endif -%}
                    </div>

                    <div class="cart-item__quantity">
                      <div class="quantity">
                        <button type="button" class="quantity__button" onclick="updateQty('updates_{{ item.key }}', -1)">-</button>
                        <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="quantity__input">
                        <button type="button" class="quantity__button" onclick="updateQty('updates_{{ item.key }}', 1)">+</button>
                      </div>
                      <a href="{{ item.url_to_remove }}" class="cart-remove__button">Remove</a>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>

          <div class="cart-page__utility">
            <div class="cart-page__discount-section">
              <h3 class="discount-section__title">Discount code</h3>
              <div class="discount-form">
                <input type="text" class="discount-form__input" id="discount-code" placeholder="Enter discount code" {% if cart.discount_codes.size > 0 %}value="{{ cart.discount_codes[0].code }}"{% endif %}>
                <button type="button" class="discount-form__button" onclick="applyDiscount()">Apply</button>
              </div>
              <div class="discount-messages">
                <div class="discount-error" id="discount-error">Invalid discount code. Please try again.</div>
                <div class="discount-success" id="discount-success">Discount applied successfully.</div>
              </div>
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="applied-discounts">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="applied-discount">
                      <span class="applied-discount__code">{{ discount.title }}</span>
                      <span class="applied-discount__amount">-{{ discount.total_allocated_amount | money }}</span>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>

            {%- if section.settings.show_cart_note -%}
              <div class="cart-page__note-card">
                <label for="cart-note" class="cart-note__label">Special instructions</label>
                <textarea name="note" id="cart-note" class="cart-note__input" placeholder="Add a note for your order">{{ cart.note }}</textarea>
              </div>
            {%- endif -%}
          </div>
        </div>

        <aside class="cart-page__summary-column">
          <div class="cart-page__totals cart-page__summary-sticky">
            <div class="cart-subtotals">
              <div class="cart-subtotals__row">
                <span>Subtotal</span>
                <span class="price">{{ cart.total_price | money }}</span>
              </div>
              <div class="cart-subtotals__row">
                <span>Shipping</span>
                <span>{% if cart.total_price >= free_shipping_threshold %}Free{% else %}Calculated at checkout{% endif %}</span>
              </div>
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="cart-subtotals__row" style="color: #1e8757;">
                  <span>Discount</span>
                  <span>-{{ cart.total_discount | money }}</span>
                </div>
              {%- endif -%}
              <div class="cart-subtotals__row cart-subtotals__total">
                <span>Total</span>
                <span>{{ cart.total_price | money }}</span>
              </div>
            </div>

            <div class="cart-subtotals__shipping">
              <p>Taxes included. Shipping calculated at checkout.</p>
              <p>Secure checkout with fast order confirmation.</p>
            </div>

            <div class="checkout-payment-icons">
              <span class="payment-icons-label">Accepted payments</span>
              <div class="payment-icons-grid">
                <span class="payment-icon">VISA</span>
                <span class="payment-icon">MasterCard</span>
                <span class="payment-icon">UPI</span>
                <span class="payment-icon">Paytm</span>
                <span class="payment-icon">GPay</span>
                <span class="payment-icon">PhonePe</span>
              </div>
            </div>

            <div class="checkout-trust-signals">
              <div class="trust-signal">
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                  <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                </svg>
                <span>Secure checkout</span>
              </div>
              <div class="trust-signal">
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                  <path d="M17 18c-1.11 0-2 .89-2 2s.89 2 2 2 2-.89 2-2-.89-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.44C5.09 14.32 5 14.65 5 15c0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.47c.08-.14.12-.31.12-.5 0-.55-.45-1-1-1H5.21l-.94-2H1zm6 16c-1.11 0-2 .89-2 2s.89 2 2 2 2-.89 2-2-.89-2-2-2z"/>
                </svg>
                <span>Easy returns</span>
              </div>
              <div class="trust-signal">
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                  <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4z"/>
                </svg>
                <span>Fast shipping updates</span>
              </div>
            </div>

            <button type="submit" name="checkout" class="cart-checkout__button">
              Proceed to Checkout
            </button>

            <a href="{{ routes.collections_url }}" class="continue-shopping__link">Continue shopping</a>
          </div>
        </aside>
      </div>
    </form>
  {%- endif -%}
</div>

<script>
  function updateQty(inputId, change) {
    const input = document.getElementById(inputId);
    const form = document.getElementById('cart-form');
    if (!input || !form) return;

    const nextValue = Math.max(0, Number(input.value || 0) + change);
    input.value = nextValue;

    clearTimeout(window.catfatCartUpdateTimer);
    window.catfatCartUpdateTimer = setTimeout(() => {
      form.requestSubmit();
    }, 120);
  }

  function applyDiscount() {
    const form = document.getElementById('cart-form');
    const codeInput = document.getElementById('discount-code');
    if (!form || !codeInput) return false;

    const code = codeInput.value.trim();
    if (!code) return false;

    let discountInput = document.getElementById('discount-code-hidden');
    if (!discountInput) {
      discountInput = document.createElement('input');
      discountInput.type = 'hidden';
      discountInput.id = 'discount-code-hidden';
      discountInput.name = 'discount';
      form.appendChild(discountInput);
    }

    discountInput.value = code;
    form.requestSubmit();
    return false;
  }
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "default": true,
      "label": "Show cart note"
    }
  ]
}
{% endschema %}
