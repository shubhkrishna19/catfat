{%- liquid
  assign guided_collection = collections['new-arrivals']
  if guided_collection == blank or guided_collection.products_count == 0
    assign guided_collection = collections['lunch-box']
  endif
-%}

<style>
  .search-page {
    padding: clamp(3.2rem, 4.8vw, 5.6rem) 0 clamp(5.2rem, 6.4vw, 7.2rem);
  }

  .search-page__hero {
    display: grid;
    gap: 1.6rem;
    justify-items: center;
    margin-bottom: clamp(3rem, 4vw, 4rem);
    text-align: center;
  }

  .search-page__title {
    margin: 0;
    color: var(--catfat-copy-strong);
    font-size: clamp(2.8rem, 2.4rem + 1vw, 4rem);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .search-page__description {
    max-width: 56rem;
    margin: 0;
    color: var(--catfat-copy-body);
    font-size: 1.5rem;
    line-height: 1.6;
    font-weight: 500;
  }

  .search-page__search-shell {
    width: min(100%, 88rem);
  }

  .search-page__search {
    position: relative;
    display: grid;
    gap: 1.2rem;
    width: min(100%, 100%);
  }

  .search-page__form {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 5.6rem;
    padding: 0.6rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 16px 34px rgba(86, 60, 105, 0.08);
  }

  .search-page__search-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 4.8rem;
    width: 4.8rem;
    color: var(--catfat-copy-muted);
  }

  .search-page__search-icon svg {
    width: 1.8rem;
    height: 1.8rem;
  }

  .search-page__input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 0 1.2rem 0 0;
    border: 0;
    background: transparent;
    color: var(--catfat-copy-strong);
    font-size: 1.5rem;
    line-height: 1.4;
    font-weight: 500;
  }

  .search-page__input::placeholder {
    color: #8a7e98;
  }

  .search-page__input:focus {
    outline: none;
  }

  .search-page__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 11.8rem;
    min-height: 4.4rem;
    padding: 0 1.6rem;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--catfat-brand-purple-soft), var(--catfat-brand-purple) 58%, var(--catfat-brand-purple-deep));
    color: #fff;
    font-size: 1.35rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 14px 26px rgba(var(--catfat-brand-purple-rgb), 0.18);
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .search-page__submit:hover,
  .search-page__submit:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 18px 30px rgba(var(--catfat-brand-purple-rgb), 0.22);
  }

  .search-page__dropdown {
    position: absolute;
    top: calc(100% + 1rem);
    left: 0;
    right: 0;
    z-index: 20;
    display: grid;
    gap: 1.8rem;
    padding: 1.8rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
    border-radius: 1.6rem;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 24px 46px rgba(70, 48, 84, 0.12);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(0.8rem);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
  }

  .search-page__search.is-open .search-page__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .search-page__dropdown-section {
    display: grid;
    gap: 1.2rem;
  }

  .search-page__dropdown-section + .search-page__dropdown-section {
    padding-top: 1.8rem;
    border-top: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
  }

  .search-page__dropdown-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .search-page__dropdown-title {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin: 0;
    color: var(--catfat-copy-strong);
    font-size: 1.35rem;
    line-height: 1.3;
    font-weight: 700;
  }

  .search-page__dropdown-title svg {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--catfat-copy-muted);
  }

  .search-page__clear-history {
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--catfat-brand-purple);
    font-size: 1.2rem;
    font-weight: 600;
    cursor: pointer;
  }

  .search-page__chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .search-page__chip,
  .search-page__recent-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.6rem;
    padding: 0.8rem 1.2rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
    border-radius: 999px;
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.06);
    color: var(--catfat-copy-strong);
    font-size: 1.28rem;
    line-height: 1.2;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease, background-color 0.22s ease;
  }

  .search-page__chip:hover,
  .search-page__chip:focus-visible,
  .search-page__recent-link:hover,
  .search-page__recent-link:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(var(--catfat-brand-purple-rgb), 0.16);
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.12);
    box-shadow: 0 10px 18px rgba(var(--catfat-brand-purple-rgb), 0.08);
  }

  .search-page__recent-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .search-page__recent-list[hidden],
  .search-page__dropdown-section[hidden] {
    display: none;
  }

  .search-page__quick-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .search-page__quick-card {
    display: grid;
    gap: 0.9rem;
    padding: 1rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
    border-radius: 1.3rem;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .search-page__quick-card:hover,
  .search-page__quick-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(var(--catfat-brand-purple-rgb), 0.16);
    box-shadow: 0 14px 26px rgba(var(--catfat-brand-purple-rgb), 0.08);
  }

  .search-page__quick-image-wrap {
    aspect-ratio: 1 / 1;
    border-radius: 1rem;
    overflow: hidden;
    background: rgba(var(--catfat-brand-purple-soft-rgb), 0.05);
  }

  .search-page__quick-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .search-page__quick-name {
    overflow: hidden;
    color: var(--catfat-copy-strong);
    font-size: 1.2rem;
    line-height: 1.35;
    font-weight: 600;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .search-page__quick-price {
    color: var(--catfat-brand-purple);
    font-size: 1.2rem;
    line-height: 1.2;
    font-weight: 700;
  }

  .search-page__results-shell {
    display: grid;
    gap: 2rem;
  }

  .search-page__results-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .search-page__results-text {
    margin: 0;
    color: var(--catfat-copy-body);
    font-size: 1.45rem;
    line-height: 1.5;
    font-weight: 500;
  }

  .search-results-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
  }

  .search-no-results {
    display: grid;
    gap: 0.8rem;
    padding: 3.2rem;
    border: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.08);
    border-radius: 1.8rem;
    background: rgba(255, 255, 255, 0.92);
    text-align: center;
  }

  .search-no-results h2 {
    margin: 0;
    color: var(--catfat-copy-strong);
    font-size: 2.2rem;
    line-height: 1.2;
    font-weight: 700;
  }

  .search-no-results p {
    margin: 0;
    color: var(--catfat-copy-body);
    font-size: 1.4rem;
    line-height: 1.6;
    font-weight: 500;
  }

  @media (max-width: 1199px) {
    .search-page__quick-grid,
    .search-results-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 989px) {
    .search-page__search-shell {
      width: 100%;
    }

    .search-page__dropdown {
      position: static;
      margin-top: 1rem;
    }

    .search-page__search.is-open .search-page__dropdown {
      display: grid;
    }

    .search-page__quick-grid,
    .search-results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 749px) {
    .search-page {
      padding: 2.4rem 0 4rem;
    }

    .search-page__hero {
      margin-bottom: 2.4rem;
    }

    .search-page__description {
      font-size: 1.4rem;
    }

    .search-page__form {
      min-height: 5.2rem;
      padding: 0.5rem;
    }

    .search-page__search-icon {
      flex-basis: 4.2rem;
      width: 4.2rem;
    }

    .search-page__input {
      font-size: 1.4rem;
      padding-right: 0.8rem;
    }

    .search-page__submit {
      min-width: 9.6rem;
      min-height: 4.2rem;
      padding: 0 1.2rem;
      font-size: 1.25rem;
    }

    .search-page__dropdown {
      gap: 1.6rem;
      padding: 1.5rem;
    }

    .search-page__dropdown-section + .search-page__dropdown-section {
      padding-top: 1.5rem;
    }

    .search-page__quick-grid,
    .search-results-grid {
      grid-template-columns: 1fr;
    }

    .search-page__quick-grid {
      grid-auto-flow: column;
      grid-auto-columns: minmax(17rem, 72%);
      overflow-x: auto;
      scrollbar-width: none;
      scroll-snap-type: x proximity;
    }

    .search-page__quick-grid::-webkit-scrollbar {
      display: none;
    }

    .search-page__quick-card {
      scroll-snap-align: start;
    }
  }
</style>

<div class="search-page page-width">
  <div class="search-page__hero">
    <h1 class="search-page__title">Search</h1>
    <p class="search-page__description">Find lunch boxes, bottles, and Catfat favourites faster with guided suggestions and quick product picks.</p>

    <div class="search-page__search-shell">
      <search-form
        class="search-page__search"
        data-guided-search
        data-initial-search-term="{{ search.terms | escape }}"
      >
        <form class="search-page__form" action="{{ routes.search_url }}" method="get">
          <span class="search-page__search-icon" aria-hidden="true">
            {% render 'icon-search' %}
          </span>
          <input
            class="search-page__input"
            type="search"
            name="q"
            placeholder="Search lunch boxes, bottles, kids themes..."
            value="{{ search.terms | escape }}"
            autocomplete="off"
          >
          <button class="search-page__submit" type="submit">Search</button>
        </form>

        <div class="search-page__dropdown" data-guided-dropdown>
          <section class="search-page__dropdown-section" data-recent-section hidden>
            <div class="search-page__dropdown-head">
              <h2 class="search-page__dropdown-title">
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M10 5.5v4.5l3 1.8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="10" cy="10" r="6.7" stroke="currentColor" stroke-width="1.6"/>
                </svg>
                Recent searches
              </h2>
              <button type="button" class="search-page__clear-history" data-clear-history>Clear history</button>
            </div>
            <div class="search-page__recent-list" data-recent-list hidden></div>
          </section>

          <section class="search-page__dropdown-section">
            <div class="search-page__dropdown-head">
              <h2 class="search-page__dropdown-title">Trending searches</h2>
            </div>
            <div class="search-page__chip-list">
              <a class="search-page__chip" href="{{ routes.search_url }}?q=Lunch+boxes">Lunch boxes</a>
              <a class="search-page__chip" href="{{ routes.search_url }}?q=Water+bottles">Water bottles</a>
              <a class="search-page__chip" href="{{ routes.search_url }}?q=Kids+lunch+sets">Kids lunch sets</a>
              <a class="search-page__chip" href="{{ routes.search_url }}?q=Leak-proof+containers">Leak-proof containers</a>
            </div>
          </section>

          {%- if guided_collection != blank and guided_collection.products_count > 0 -%}
            <section class="search-page__dropdown-section">
              <div class="search-page__dropdown-head">
                <h2 class="search-page__dropdown-title">New arrivals</h2>
              </div>
              <div class="search-page__quick-grid">
                {%- for product in guided_collection.products limit: 4 -%}
                  <a class="search-page__quick-card" href="{{ product.url }}">
                    <div class="search-page__quick-image-wrap">
                      {%- if product.featured_media != blank -%}
                        {{
                          product.featured_media
                          | image_url: width: 420
                          | image_tag:
                            class: 'search-page__quick-image',
                            widths: '180, 240, 320, 420',
                            loading: 'lazy',
                            alt: product.title
                        }}
                      {%- endif -%}
                    </div>
                    <span class="search-page__quick-name">{{ product.title }}</span>
                    <span class="search-page__quick-price">
                      {%- if product.price_varies -%}
                        From {{ product.price_min | money }}
                      {%- else -%}
                        {{ product.price | money }}
                      {%- endif -%}
                    </span>
                  </a>
                {%- endfor -%}
              </div>
            </section>
          {%- endif -%}
        </div>
      </search-form>
    </div>
  </div>

  {%- if search.performed -%}
    <div class="search-page__results-shell">
      {%- if search.results_count == 0 -%}
        <div class="search-no-results">
          <h2>No results found for "{{ search.terms }}"</h2>
          <p>Try a shorter search phrase or use the guided suggestions above.</p>
        </div>
      {%- else -%}
        <div class="search-page__results-meta">
          <p class="search-page__results-text">{{ search.results_count }} results found for "{{ search.terms }}"</p>
        </div>
        <div class="search-results-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'card-product', card_product: item %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
