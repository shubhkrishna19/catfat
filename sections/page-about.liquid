{{ 'section-page-about.css' | asset_url | stylesheet_tag }}

<section class="catfat-about" aria-labelledby="CatfatAboutTitle-{{ section.id }}">
  <div class="catfat-about__inner">
    <div class="catfat-about__grid">
      <div class="catfat-about__intro">
        <h1 id="CatfatAboutTitle-{{ section.id }}" class="catfat-about__title">
          <span>ABOUT</span>
          <span>US</span>
        </h1>
        <span class="catfat-about__accent" aria-hidden="true"></span>
        <div class="catfat-about__lead">
          <p class="catfat-about__lead-strong">Built from real routines.</p>
          <p>Designed for everyday joy.</p>
        </div>
        <p class="catfat-about__copy">
          Catfat India creates lunchware and hydration essentials that make school, work, and family meals feel simpler and better designed.
        </p>
      </div>

      <div class="catfat-about__team-media">
        {%- if section.settings.team_image != blank -%}
          {{
            section.settings.team_image
            | image_url: width: 1200
            | image_tag:
              class: 'catfat-about__team-image',
              widths: '480, 720, 960, 1200',
              loading: 'eager',
              alt: section.settings.team_image_alt
          }}
        {%- else -%}
          <img
            src="{{ 'catfat-about-team.jpg' | asset_url }}"
            alt="{{ section.settings.team_image_alt | escape }}"
            class="catfat-about__team-image"
            loading="eager"
            width="738"
            height="494"
          >
        {%- endif -%}
      </div>

      <aside class="catfat-about__founders" aria-label="Our founders">
        <div class="catfat-about__founder-media">
          {%- if section.settings.founder_image != blank -%}
            {{
              section.settings.founder_image
              | image_url: width: 720
              | image_tag:
                class: 'catfat-about__founder-image',
                widths: '360, 540, 720',
                loading: 'lazy',
                alt: section.settings.founder_image_alt
            }}
          {%- else -%}
            <img
              src="{{ 'catfat-founders.jpg' | asset_url }}"
              alt="{{ section.settings.founder_image_alt | escape }}"
              class="catfat-about__founder-image"
              loading="lazy"
              width="738"
              height="850"
            >
          {%- endif -%}
        </div>

        <p class="catfat-about__label">OUR FOUNDERS</p>

        <div class="catfat-about__founder">
          <h2>Gaurav Goyal</h2>
          <p class="catfat-about__role">CO-FOUNDER</p>
          <p>Leads Catfat India's product direction with a focus on practical, family-ready lunchware.</p>
        </div>

        <div class="catfat-about__divider" aria-hidden="true"></div>

        <div class="catfat-about__founder">
          <h2>Sarita Sharma Goyal</h2>
          <p class="catfat-about__role">CO-FOUNDER</p>
          <p>Shapes the brand experience around everyday use, thoughtful details, and customer trust.</p>
        </div>
      </aside>
    </div>

    <div class="catfat-about__vision">
      <div class="catfat-about__vision-main">
        <span class="catfat-about__vision-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M4 12c4.5-7 11.5-7 16 0-4.5 7-11.5 7-16 0Z"></path>
            <path d="M9 12a3 3 0 1 0 6 0 3 3 0 0 0-6 0Z"></path>
          </svg>
        </span>
        <div>
          <p class="catfat-about__vision-title">We're redefining India's mealtime experience</p>
          <p class="catfat-about__vision-copy">by merging style, functionality, and safety into one product ecosystem.</p>
        </div>
      </div>
      <p class="catfat-about__trust">
        CatfatIndia has built one of India's largest organic lifestyle communities in the mealtime & hydration category.
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "team_image",
      "label": "Team image"
    },
    {
      "type": "text",
      "id": "team_image_alt",
      "label": "Team image alt text",
      "default": "Catfat India team"
    },
    {
      "type": "image_picker",
      "id": "founder_image",
      "label": "Founder image"
    },
    {
      "type": "text",
      "id": "founder_image_alt",
      "label": "Founder image alt text",
      "default": "Catfat India founders"
    }
  ],
  "presets": [
    {
      "name": "About Page"
    }
  ]
}
{% endschema %}
