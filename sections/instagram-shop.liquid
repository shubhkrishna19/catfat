<!-- Instagram Shop Integration Section -->
{%- style -%}
.instagram-shop-section {
  padding: 60px 0;
  background: linear-gradient(135deg, #fff5f8 0%, #fff 50%, #fff5f8 100%);
}

.instagram-shop-section .section-header {
  text-align: center;
  margin-bottom: 40px;
}

.instagram-shop-section .shop-title {
  font-size: 2.5rem;
  font-weight: 800;
  color: #e84a7f;
  margin: 0 0 15px;
}

.instagram-shop-section .shop-title::after {
  content: '';
  display: block;
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #ff6b9d, #e84a7f);
  margin: 15px auto 0;
  border-radius: 2px;
}

.instagram-shop-section .shop-subtitle {
  font-size: 1.1rem;
  color: #666;
  margin: 0;
}

.shop-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 30px;
}

.shop-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 16px;
  overflow: hidden;
  cursor: pointer;
  background: #f5f5f5;
}

.shop-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.shop-item:hover img {
  transform: scale(1.1);
}

.shop-item .shop-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(232, 74, 127, 0.85), rgba(255, 107, 157, 0.85));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.shop-item:hover .shop-overlay {
  opacity: 1;
}

.shop-item .shop-overlay svg {
  width: 32px;
  height: 32px;
  color: #fff;
  margin-bottom: 8px;
}

.shop-item .shop-overlay span {
  color: #fff;
  font-weight: 600;
  font-size: 0.9rem;
}

.instagram-shop-section .cta-container {
  text-align: center;
}

.shop-all-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 40px;
  background: linear-gradient(135deg, #e84a7f, #ff6b9d);
  color: #fff;
  text-decoration: none;
  border-radius: 30px;
  font-weight: 700;
  font-size: 1.1rem;
  transition: all 0.3s ease;
}

.shop-all-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 35px rgba(232, 74, 127, 0.4);
}

.shop-all-btn svg {
  width: 20px;
  height: 20px;
}

@media (max-width: 1024px) {
  .shop-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .instagram-shop-section .shop-title {
    font-size: 1.8rem;
  }
  
  .shop-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
}
{%- endstyle -%}

<div class="instagram-shop-section section">
  <div class="page-width">
    <div class="section-header">
      <h2 class="shop-title">Shop on Instagram</h2>
      <p class="shop-subtitle">Tag us to be featured and shop directly from our Instagram</p>
    </div>
    
    <div class="shop-grid">
      {%- for i in (1..4) -%}
        <div class="shop-item">
          {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
          <div class="shop-overlay">
            {% render 'icon-instagram' %}
            <span>Shop Now</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
    
    <div class="cta-container">
      <a href="https://instagram.com/shop/catfatindia" target="_blank" class="shop-all-btn">
        {% render 'icon-instagram' %}
        Shop All on Instagram
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Instagram Shop",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Shop on Instagram",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "presets": [
    {
      "name": "Instagram Shop"
    }
  ]
}
{% endschema %}
