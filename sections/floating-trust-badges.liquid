{%- style -%}
  body.has-floating-trust-bar {
    padding-bottom: var(--floating-trust-bar-offset, 7.6rem);
  }

  body.has-floating-trust-bar .custom_bottom_whatsapp_btn {
    bottom: calc(var(--floating-trust-bar-offset, 7.6rem) + 20px);
  }

  .floating-trust-bar {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1200;
    border-top: 1px solid rgba(var(--catfat-brand-purple-rgb), 0.12);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 -12px 28px rgba(var(--catfat-brand-purple-rgb), 0.08);
    backdrop-filter: blur(16px);
  }

  .floating-trust-bar .trust-badges-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.6rem, 2.6vw, 3.6rem);
    max-width: 1380px;
    min-height: 7.4rem;
    margin: 0 auto;
    padding: 1.1rem clamp(1.8rem, 3vw, 3.2rem);
  }

  .floating-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    flex: 0 0 auto;
    color: #2f2740;
  }

  .floating-trust-badge svg {
    width: 2.4rem;
    height: 2.4rem;
    flex-shrink: 0;
    color: #642878;
  }

  .floating-trust-badge .badge-text {
    display: grid;
    gap: 0.2rem;
  }

  .floating-trust-badge .badge-label {
    color: #6f6580;
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: 0.02em;
  }

  .floating-trust-badge .badge-value {
    color: #2f2740;
    font-size: 1.36rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  @media (max-width: 990px) {
    .floating-trust-bar .trust-badges-container {
      gap: 2rem;
      min-height: 6.8rem;
      padding-inline: 2rem;
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .floating-trust-bar .trust-badges-container::-webkit-scrollbar {
      display: none;
    }
  }

  @media (max-width: 480px) {
    body.has-floating-trust-bar .custom_bottom_whatsapp_btn {
      bottom: calc(var(--floating-trust-bar-offset, 7.2rem) + 12px);
    }

    .floating-trust-bar .trust-badges-container {
      gap: 1.6rem;
      min-height: 6.4rem;
      padding: 1rem 1.6rem;
    }

    .floating-trust-badge {
      gap: 0.8rem;
    }

    .floating-trust-badge svg {
      width: 2.1rem;
      height: 2.1rem;
    }

    .floating-trust-badge .badge-label {
      font-size: 1.05rem;
    }

    .floating-trust-badge .badge-value {
      font-size: 1.24rem;
    }
  }
{%- endstyle -%}

<div class="floating-trust-bar" id="floatingTrustBar" aria-label="Store trust highlights">
  <div class="trust-badges-container">
    <div class="floating-trust-badge">
      {% render 'icon-truck' %}
      <div class="badge-text">
        <span class="badge-label">Free Shipping</span>
        <span class="badge-value">Above Rs. 499</span>
      </div>
    </div>

    <div class="floating-trust-badge">
      {% render 'icon-checkmark' %}
      <div class="badge-text">
        <span class="badge-label">Verified</span>
        <span class="badge-value">100% Original</span>
      </div>
    </div>

    <div class="floating-trust-badge">
      {% render 'icon-chat' %}
      <div class="badge-text">
        <span class="badge-label">WhatsApp</span>
        <span class="badge-value">Support Available</span>
      </div>
    </div>

    <div class="floating-trust-badge">
      {% render 'icon-success' %}
      <div class="badge-text">
        <span class="badge-label">Easy Returns</span>
        <span class="badge-value">7 Days Return</span>
      </div>
    </div>

    <div class="floating-trust-badge">
      {% render 'icon-credit-card' %}
      <div class="badge-text">
        <span class="badge-label">COD</span>
        <span class="badge-value">Available</span>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const updateFloatingTrustBar = () => {
      const floatingBar = document.getElementById('floatingTrustBar');
      if (!floatingBar || !document.body) return;

      const floatingBarHeight = Math.ceil(floatingBar.getBoundingClientRect().height);
      document.documentElement.style.setProperty('--floating-trust-bar-offset', `${floatingBarHeight}px`);
      document.body.classList.add('has-floating-trust-bar');
    };

    const initializeFloatingTrustBar = () => {
      updateFloatingTrustBar();
      window.addEventListener('resize', updateFloatingTrustBar);
    };

    document.addEventListener('DOMContentLoaded', initializeFloatingTrustBar);
    document.addEventListener('shopify:section:load', updateFloatingTrustBar);
    document.addEventListener('shopify:section:reorder', updateFloatingTrustBar);
  })();
</script>

{% schema %}
{
  "name": "Floating Trust Badges",
  "settings": [
    {
      "type": "paragraph",
      "content": "Fixed trust bar displayed at the bottom of the screen."
    }
  ],
  "presets": [
    {
      "name": "Floating Trust Badges"
    }
  ]
}
{% endschema %}
