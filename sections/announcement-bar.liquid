{%- if section.settings.text != blank -%}
  <div
    id="announcement-bar-{{ section.id }}"
    class="announcement-bar"
    style="--announcement-background: {{ section.settings.background_color }}; --announcement-text: {{ section.settings.text_color }};"
  >
    <div class="announcement-bar__inner">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__text">
          {{ section.settings.text }}
        </a>
      {%- else -%}
        <p class="announcement-bar__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.settings.enable_close -%}
        <button
          type="button"
          class="announcement-bar__close"
          aria-label="Close announcement"
          data-announcement-close
        >
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="M5 5L15 15"></path>
            <path d="M15 5L5 15"></path>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </div>

  <script>
    (() => {
      const bar = document.getElementById('announcement-bar-{{ section.id }}');
      if (!bar) return;

      const storageKey = 'catfat-announcement-{{ section.id }}-dismissed';
      const closeButton = bar.querySelector('[data-announcement-close]');

      try {
        if (window.localStorage.getItem(storageKey) === 'true') {
          bar.hidden = true;
        }
      } catch (error) {}

      if (!closeButton) return;

      closeButton.addEventListener('click', () => {
        bar.hidden = true;

        try {
          window.localStorage.setItem(storageKey, 'true');
        } catch (error) {}
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "Free shipping above ₹499 | COD available | Get extra 20% off with SWEETCAT20",
      "label": "Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "enable_close",
      "default": true,
      "label": "Enable close button"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#6d4a8d",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#ffffff",
      "label": "Text color"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
