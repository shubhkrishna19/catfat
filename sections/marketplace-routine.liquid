{{ 'section-marketplace-routine.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign lunch_collection = collections['lunch-box']
  assign kids_collection = collections['kids-collections']
  assign gifting_collection = collections['corporate-gifting-bulk-gifting']

  assign lunch_product = blank
  if lunch_collection != blank
    for product in lunch_collection.products
      if product.available
        assign lunch_product = product
        break
      endif
    endfor
    if lunch_product == blank
      assign lunch_product = lunch_collection.products.first
    endif
  endif

  assign kids_product = blank
  if kids_collection != blank
    for product in kids_collection.products
      if product.available
        assign kids_product = product
        break
      endif
    endfor
    if kids_product == blank
      assign kids_product = kids_collection.products.first
    endif
  endif

  assign gifting_product = blank
  if gifting_collection != blank
    for product in gifting_collection.products
      if product.available
        assign gifting_product = product
        break
      endif
    endfor
    if gifting_product == blank
      assign gifting_product = gifting_collection.products.first
    endif
  endif
-%}

<section class="routine-story page-width">
  <div class="routine-story__shell">
    <div class="routine-story__copy">
      <span class="routine-story__eyebrow">Theme and gifting spotlight</span>
      <h2 class="routine-story__title">Themes kids notice. Picks that feel gift-ready.</h2>
      <p class="routine-story__description">
        Bring the playful side of Catfat forward with character-led lunchware, personalised picks, and gifting-friendly options that feel special before checkout even starts.
      </p>

      <div class="routine-story__signals">
        <span class="routine-story__signal">Kids-favourite themes</span>
        <span class="routine-story__signal">Return-gift friendly</span>
        <span class="routine-story__signal">Bulk gifting help</span>
      </div>

      {%- if kids_collection != blank -%}
        <a href="{{ kids_collection.url }}" class="routine-story__button">Explore kids themes</a>
      {%- endif -%}
    </div>

    <div class="routine-story__stage">
      <div class="routine-story__stage-base"></div>
      <div class="routine-story__orb routine-story__orb--one"></div>
      <div class="routine-story__orb routine-story__orb--two"></div>

      {%- if lunch_product != blank and lunch_product.featured_media != blank -%}
        <div class="routine-story__float routine-story__float--lunch">
          {{
            lunch_product.featured_media
            | image_url: width: 900
            | image_tag:
              class: 'routine-story__product-image',
              widths: '320, 480, 680, 900',
              loading: 'lazy',
              alt: lunch_product.title
          }}
        </div>
      {%- endif -%}

      {%- if kids_product != blank and kids_product.featured_media != blank -%}
        <div class="routine-story__float routine-story__float--bottle">
          {{
            kids_product.featured_media
            | image_url: width: 900
            | image_tag:
              class: 'routine-story__product-image',
              widths: '320, 480, 680, 900',
              loading: 'lazy',
              alt: kids_product.title
          }}
        </div>
      {%- endif -%}

      {%- if gifting_product != blank and gifting_product.featured_media != blank -%}
        <div class="routine-story__float routine-story__float--gift">
          {{
            gifting_product.featured_media
            | image_url: width: 900
            | image_tag:
              class: 'routine-story__product-image',
              widths: '320, 480, 680, 900',
              loading: 'lazy',
              alt: gifting_product.title
          }}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="routine-story__grid">
    {%- if kids_collection != blank -%}
      <a href="{{ kids_collection.url }}" class="routine-story__card">
        <span class="routine-story__card-label">Kids themes</span>
        <strong class="routine-story__card-title">Character picks that make the product feel exciting instantly.</strong>
        <p class="routine-story__card-copy">A cleaner route into themed lunchware that feels playful without making the homepage noisy.</p>
      </a>
    {%- endif -%}

    {%- if lunch_collection != blank -%}
      <a href="{{ lunch_collection.url }}" class="routine-story__card">
        <span class="routine-story__card-label">Gifting-ready range</span>
        <strong class="routine-story__card-title">Lunchware that still feels practical after the gift moment.</strong>
        <p class="routine-story__card-copy">Use the bestseller range as the easy bridge between everyday utility and presentable gifting value.</p>
      </a>
    {%- endif -%}

    {%- if gifting_collection != blank -%}
      <a href="{{ gifting_collection.url }}" class="routine-story__card">
        <span class="routine-story__card-label">Bulk gifting</span>
        <strong class="routine-story__card-title">Personalised and return-gift picks for bigger order moments.</strong>
        <p class="routine-story__card-copy">A clearer lane for bulk gifting, customisation, and faster shortlist decisions when quantity matters.</p>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Marketplace Routine",
  "settings": [],
  "presets": [
    {
      "name": "Marketplace Routine"
    }
  ]
}
{% endschema %}
