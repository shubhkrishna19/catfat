{{ 'section-marketplace-routine.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign school_collection = collections['lunch-box']
  assign carry_collection = collections['bottles-flasks']
  assign family_collection = collections['corporate-gifting-bulk-gifting']

  assign school_url = routes.collections_url
  if school_collection != blank and school_collection.url != blank
    assign school_url = school_collection.url
  endif

  assign carry_url = routes.collections_url
  if carry_collection != blank and carry_collection.url != blank
    assign carry_url = carry_collection.url
  endif

  assign family_url = routes.collections_url
  if family_collection != blank and family_collection.url != blank
    assign family_url = family_collection.url
  endif

  # Priority: theme editor upload > bundled brand fallback. Collection
  # auto-fetch removed because it was pulling plain product shots with no
  # background, which didn't read as routine moments.
  assign school_media = section.settings.school_image
  assign school_alt = 'Schoolgirl heading out with Catfat bottle'

  assign carry_media = section.settings.carry_image
  assign carry_alt = 'Catfat lunch box flat-lay with bottle'

  assign family_media = section.settings.family_image
  assign family_alt = 'Catfat premium gift moments'
-%}

<section class="routine-story">
  <div class="page-width">
    <div class="routine-story__inner">
      <div class="routine-story__header" data-scrub data-scrub-y="28" data-scrub-opacity-from="0">
        <h2 class="routine-story__title">Made for every lunch moment</h2>
        <p class="routine-story__description">
          From school tiffins to family outings, Catfat makes everyday meals easier, safer, and more joyful.
        </p>
      </div>

      <div class="routine-story__grid">
        <a href="{{ school_url }}" class="routine-story__item routine-story__item--school" data-card-depth data-scrub-from="0.05">
          <div class="routine-story__media">
            {%- if school_media != blank -%}
              {{
                school_media
                | image_url: width: 960
                | image_tag:
                  class: 'routine-story__image',
                  widths: '360, 540, 720, 960',
                  loading: 'lazy',
                  alt: school_alt
              }}
            {%- else -%}
              <img src="{{ 'catfat-routine-school.jpg' | asset_url }}" class="routine-story__image" alt="Schoolgirl heading out with Catfat bottle" loading="lazy" width="720" height="960">
            {%- endif -%}
          </div>
          <span class="routine-story__caption">For school days</span>
        </a>

        <a href="{{ carry_url }}" class="routine-story__item routine-story__item--carry" data-card-depth data-scrub-from="0.12">
          <div class="routine-story__media">
            {%- if carry_media != blank -%}
              {{
                carry_media
                | image_url: width: 960
                | image_tag:
                  class: 'routine-story__image',
                  widths: '360, 540, 720, 960',
                  loading: 'lazy',
                  alt: carry_alt
              }}
            {%- else -%}
              <img src="{{ 'catfat-smart-lunch-flatlay.jpg' | asset_url }}" class="routine-story__image" alt="Catfat lunch box flat-lay with bottle" loading="lazy" width="960" height="640">
            {%- endif -%}
          </div>
          <span class="routine-story__caption">For everyday carry</span>
        </a>

        <a href="{{ family_url }}" class="routine-story__item routine-story__item--family" data-card-depth data-scrub-from="0.2">
          <div class="routine-story__media">
            {%- if family_media != blank -%}
              {{
                family_media
                | image_url: width: 960
                | image_tag:
                  class: 'routine-story__image',
                  widths: '360, 540, 720, 960',
                  loading: 'lazy',
                  alt: family_alt
              }}
            {%- else -%}
              <img src="{{ 'catfat-corporate-gift.jpg' | asset_url }}" class="routine-story__image" alt="Catfat premium gift box" loading="lazy" width="960" height="720">
            {%- endif -%}
          </div>
          <span class="routine-story__caption">For family moments</span>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marketplace Routine",
  "settings": [
    { "type": "image_picker", "id": "school_image", "label": "School-days image (override)" },
    { "type": "image_picker", "id": "carry_image", "label": "Everyday-carry image (override)" },
    { "type": "image_picker", "id": "family_image", "label": "Family-moments image (override)" }
  ],
  "presets": [
    {
      "name": "Marketplace Routine"
    }
  ]
}
{% endschema %}
