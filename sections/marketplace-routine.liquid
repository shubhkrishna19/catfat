{{ 'section-marketplace-routine.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign lunch_collection = collections['lunch-box']
  assign bottle_collection = collections['bottles-flasks']
  assign gifting_collection = collections['corporate-gifting-bulk-gifting']

  assign lunch_product = blank
  if lunch_collection != blank
    for product in lunch_collection.products
      if product.available
        assign lunch_product = product
        break
      endif
    endfor
    if lunch_product == blank
      assign lunch_product = lunch_collection.products.first
    endif
  endif

  assign bottle_product = blank
  if bottle_collection != blank
    for product in bottle_collection.products
      if product.available
        assign bottle_product = product
        break
      endif
    endfor
    if bottle_product == blank
      assign bottle_product = bottle_collection.products.first
    endif
  endif

  assign gifting_product = blank
  if gifting_collection != blank
    for product in gifting_collection.products
      if product.available
        assign gifting_product = product
        break
      endif
    endfor
    if gifting_product == blank
      assign gifting_product = gifting_collection.products.first
    endif
  endif
-%}

<section class="routine-story page-width">
  <div class="routine-story__shell">
    <div class="routine-story__copy">
      <span class="routine-story__eyebrow">One brand, many routines</span>
      <h2 class="routine-story__title">Lunch boxes first. Everything else made to match.</h2>
      <p class="routine-story__description">
        Start with Catfat lunch-box bestsellers, add bottles and thermos for daily carry, and keep personalised gifting picks ready for birthdays, return gifts, and bulk orders.
      </p>

      <div class="routine-story__signals">
        <span class="routine-story__signal">Lunch-box bestsellers</span>
        <span class="routine-story__signal">Bottles that match</span>
        <span class="routine-story__signal">Bulk gifting available</span>
      </div>

      {%- if lunch_collection != blank -%}
        <a href="{{ lunch_collection.url }}" class="routine-story__button">Shop bestsellers</a>
      {%- endif -%}
    </div>

    <div class="routine-story__stage">
      <div class="routine-story__stage-base"></div>
      <div class="routine-story__orb routine-story__orb--one"></div>
      <div class="routine-story__orb routine-story__orb--two"></div>

      {%- if lunch_product != blank and lunch_product.featured_media != blank -%}
        <div class="routine-story__float routine-story__float--lunch">
          {{
            lunch_product.featured_media
            | image_url: width: 900
            | image_tag:
              class: 'routine-story__product-image',
              widths: '320, 480, 680, 900',
              loading: 'lazy',
              alt: lunch_product.title
          }}
        </div>
      {%- endif -%}

      {%- if bottle_product != blank and bottle_product.featured_media != blank -%}
        <div class="routine-story__float routine-story__float--bottle">
          {{
            bottle_product.featured_media
            | image_url: width: 900
            | image_tag:
              class: 'routine-story__product-image',
              widths: '320, 480, 680, 900',
              loading: 'lazy',
              alt: bottle_product.title
          }}
        </div>
      {%- endif -%}

      {%- if gifting_product != blank and gifting_product.featured_media != blank -%}
        <div class="routine-story__float routine-story__float--gift">
          {{
            gifting_product.featured_media
            | image_url: width: 900
            | image_tag:
              class: 'routine-story__product-image',
              widths: '320, 480, 680, 900',
              loading: 'lazy',
              alt: gifting_product.title
          }}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="routine-story__grid">
    {%- if lunch_collection != blank -%}
      <a href="{{ lunch_collection.url }}" class="routine-story__card">
        <span class="routine-story__card-label">Best sellers</span>
        <strong class="routine-story__card-title">Lunch boxes shoppers can compare at a glance.</strong>
        <p class="routine-story__card-copy">Compartment-first picks with strong visuals and faster everyday decision making.</p>
      </a>
    {%- endif -%}

    {%- if bottle_collection != blank -%}
      <a href="{{ bottle_collection.url }}" class="routine-story__card">
        <span class="routine-story__card-label">Complete the carry</span>
        <strong class="routine-story__card-title">Insulated bottles and thermos to finish the set.</strong>
        <p class="routine-story__card-copy">Hydration products that feel coordinated with the lunch-box range, not separated from it.</p>
      </a>
    {%- endif -%}

    {%- if gifting_collection != blank -%}
      <a href="{{ gifting_collection.url }}" class="routine-story__card">
        <span class="routine-story__card-label">Beyond school use</span>
        <strong class="routine-story__card-title">Bulk gifting and personalised picks for bigger moments.</strong>
        <p class="routine-story__card-copy">A cleaner path for return gifts, customisation, and larger gifting enquiries.</p>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Marketplace Routine",
  "settings": [],
  "presets": [
    {
      "name": "Marketplace Routine"
    }
  ]
}
{% endschema %}
