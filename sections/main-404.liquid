{%- style -%}
  /* CATFATINDIA Pink/Coral Theme Customizations for 404 Page */
  .template-404 .title {
    color: #642878;
  }

  .template-404 .title + * {
    margin-top: 1rem;
  }

  @media screen and (min-width: 750px) {
    .template-404 .title + * {
      margin-top: 2rem;
    }
  }

  .template-404 p {
    color: #666666;
    font-size: 1.1rem;
  }

  .template-404 .button {
    background-color: #741CB1;
    border-color: #741CB1;
    color: #ffffff;
    margin-top: 2rem;
  }

  .template-404 .button:hover {
    background-color: #642878;
    border-color: #642878;
  }

  .template-404 .page-margin {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .template-404 .error-icon {
    font-size: 8rem;
    color: #741CB1;
    margin-bottom: 1rem;
  }

  .template-404 .error-code {
    font-size: 10rem;
    font-weight: bold;
    color: #5C34BA;
    line-height: 1;
    margin-bottom: 1rem;
  }

  @media screen and (max-width: 749px) {
    .template-404 .error-code {
      font-size: 6rem;
    }
  }

  [data-standard-404][hidden],
  [data-account-404-fallback][hidden] {
    display: none !important;
  }
{%- endstyle -%}

<div data-account-404-fallback hidden>
  {% render 'customer-account-fallback', customer: customer %}
</div>

<div data-standard-404>
  <div class="template-404 page-width page-margin center">
    <div class="error-code">404</div>
    <p>
      {{ 'templates.404.subtext' | t }}
    </p>
    <h1 class="title">
      {{ 'templates.404.title' | t }}
    </h1>
    <p>Sorry, the page you're looking for doesn't exist or has been moved.</p>
    <a href="{{ routes.all_products_collection_url }}" class="button">
      {{ 'general.continue_shopping' | t }}
    </a>
  </div>
</div>

<script>
  (function () {
    var path = window.location.pathname || '';
    var accountPreviewRoute = /\/\d+\/account(?:\/|$)/.test(path) || /\/account(?:\/|$)/.test(path);
    if (!accountPreviewRoute) return;

    var fallback = document.querySelector('[data-account-404-fallback]');
    var standard404 = document.querySelector('[data-standard-404]');

    if (fallback) fallback.hidden = false;
    if (standard404) standard404.hidden = true;
  })();
</script>

{% schema %}
{
  "name": "404 page",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "404 page"
    }
  ]
}
{% endschema %}

