<!-- Instagram Feed Section -->
{%- style -%}
.instagram-section {
  padding: 60px 0;
  background: #fff;
}

.instagram-section .section-header {
  text-align: center;
  margin-bottom: 40px;
}

.instagram-section .instagram-title {
  font-size: 2.5rem;
  font-weight: 800;
  color: #e84a7f;
  margin: 0 0 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.instagram-section .instagram-title svg {
  width: 32px;
  height: 32px;
}

.instagram-section .instagram-title::after {
  content: '';
  display: block;
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #ff6b9d, #e84a7f);
  margin: 15px auto 0;
  border-radius: 2px;
}

.instagram-section .instagram-subtitle {
  font-size: 1.1rem;
  color: #666;
  margin: 0;
}

.instagram-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 15px;
}

.instagram-post {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 12px;
  cursor: pointer;
  background: #f5f5f5;
}

.instagram-post img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.instagram-post:hover img {
  transform: scale(1.1);
}

.instagram-post .overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(232, 74, 127, 0.8), rgba(255, 107, 157, 0.8));
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.instagram-post:hover .overlay {
  opacity: 1;
}

.instagram-post .overlay svg {
  width: 32px;
  height: 32px;
  color: #fff;
}

.instagram-section .instagram-cta {
  text-align: center;
  margin-top: 30px;
}

.instagram-section .instagram-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  background: linear-gradient(135deg, #e84a7f, #ff6b9d);
  color: #fff;
  text-decoration: none;
  border-radius: 30px;
  font-weight: 600;
  font-size: 1rem;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.instagram-section .instagram-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(232, 74, 127, 0.4);
}

@media (max-width: 1024px) {
  .instagram-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .instagram-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .instagram-section .instagram-title {
    font-size: 1.8rem;
  }
}
{%- endstyle -%}

<div class="instagram-section section">
  <div class="page-width">
    <div class="section-header">
      <h2 class="instagram-title">
        {% render 'icon-instagram' %}
        Follow Us @CatFatIndia
      </h2>
      <p class="instagram-subtitle">Tag us to be featured! #CatFatIndia</p>
    </div>
    
    <div class="instagram-grid">
      {%- for i in (1..5) -%}
        <div class="instagram-post">
          {%- assign placeholder_image = 'product-' | append: i -%}
          {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
          <div class="overlay">
            {% render 'icon-instagram' %}
          </div>
        </div>
      {%- endfor -%}
    </div>
    
    <div class="instagram-cta">
      <a href="https://instagram.com/catfatindia" target="_blank" class="instagram-btn">
        {% render 'icon-instagram' %}
        Follow on Instagram
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Instagram Feed",
  "settings": [
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Instagram Handle",
      "default": "@catfatindia"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Follow on Instagram"
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed"
    }
  ]
}
{% endschema %}
