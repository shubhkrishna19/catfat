<!-- Testimonial Carousel Section -->
{%- style -%}
.testimonial-section {
  padding: 80px 0;
  background: linear-gradient(180deg, #fff5f8 0%, #fff 100%);
}

.testimonial-section .section-header {
  text-align: center;
  margin-bottom: 50px;
}

.testimonial-section .testimonial-title {
  font-size: 2.5rem;
  font-weight: 800;
  color: #e84a7f;
  margin: 0 0 15px;
}

.testimonial-section .testimonial-title::after {
  content: '';
  display: block;
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #ff6b9d, #e84a7f);
  margin: 15px auto 0;
  border-radius: 2px;
}

.testimonial-section .testimonial-subtitle {
  font-size: 1.1rem;
  color: #666;
  margin: 0;
}

.testimonial-carousel {
  position: relative;
  max-width: 800px;
  margin: 0 auto;
  overflow: hidden;
}

.testimonial-track {
  display: flex;
  transition: transform 0.5s ease-in-out;
}

.testimonial-slide {
  min-width: 100%;
  padding: 0 20px;
}

.testimonial-card {
  background: #fff;
  border-radius: 20px;
  padding: 40px;
  box-shadow: 0 10px 40px rgba(232, 74, 127, 0.1);
  text-align: center;
}

.testimonial-stars {
  display: flex;
  justify-content: center;
  gap: 4px;
  margin-bottom: 20px;
}

.testimonial-stars svg {
  width: 24px;
  height: 24px;
  fill: #ffc107;
  color: #ffc107;
}

.testimonial-text {
  font-size: 1.2rem;
  line-height: 1.8;
  color: #333;
  margin: 0 0 25px;
  font-style: italic;
}

.testimonial-author {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15px;
}

.testimonial-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1.5rem;
  font-weight: 700;
}

.testimonial-info {
  text-align: left;
}

.testimonial-name {
  font-weight: 700;
  color: #333;
  margin: 0 0 4px;
}

.testimonial-verified {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.85rem;
  color: #28a745;
}

.testimonial-verified svg {
  width: 14px;
  height: 14px;
}

.testimonial-location {
  font-size: 0.9rem;
  color: #666;
  margin: 4px 0 0;
}

.carousel-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  margin-top: 30px;
}

.carousel-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 2px solid #e84a7f;
  background: #fff;
  color: #e84a7f;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.carousel-btn:hover {
  background: #e84a7f;
  color: #fff;
}

.carousel-btn svg {
  width: 20px;
  height: 20px;
}

.carousel-dots {
  display: flex;
  gap: 8px;
}

.carousel-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #ddd;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.carousel-dot.active {
  background: #e84a7f;
  transform: scale(1.2);
}

@media (max-width: 768px) {
  .testimonial-section {
    padding: 50px 0;
  }
  
  .testimonial-section .testimonial-title {
    font-size: 1.8rem;
  }
  
  .testimonial-card {
    padding: 25px;
  }
  
  .testimonial-text {
    font-size: 1rem;
  }
}
{%- endstyle -%}

