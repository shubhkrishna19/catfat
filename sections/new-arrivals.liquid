{{ 'section-new-arrivals.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign arrivals_collection = section.settings.collection
  if arrivals_collection != blank and arrivals_collection.url == blank
    assign arrivals_collection = collections[section.settings.collection]
  endif

  if arrivals_collection == blank
    assign arrivals_collection = collections['new-arrivals']
  endif

  assign section_title = section.settings.title | default: 'New Arrivals'
  assign section_subtitle = section.settings.subtitle | default: 'Fresh picks for everyday meals'
  assign collection_url = routes.collections_url
  if arrivals_collection != blank and arrivals_collection.url != blank
    assign collection_url = arrivals_collection.url
  endif

  assign anchor_image = section.settings.anchor_image
  if anchor_image == blank and arrivals_collection != blank and arrivals_collection.image != blank
    assign anchor_image = arrivals_collection.image
  endif

  if anchor_image == blank and arrivals_collection != blank and arrivals_collection.featured_image != blank
    assign anchor_image = arrivals_collection.featured_image
  endif

  assign anchor_alt = section.settings.anchor_image_alt | default: section_title
  if anchor_image == blank and arrivals_collection != blank
    for product in arrivals_collection.products
      if product.featured_media != blank
        assign anchor_image = product.featured_media.preview_image
        assign anchor_alt = product.title
        break
      endif
    endfor
  endif

  assign products_limit = section.settings.products_to_show | default: 8
  assign carousel_id = 'new-arrivals-rail-' | append: section.id
-%}

<section class="new-arrivals-showcase">
  <div class="page-width">
    <div class="new-arrivals-showcase__layout" id="new-arrivals-showcase-{{ section.id }}">
      <a href="{{ collection_url }}" class="new-arrivals-showcase__anchor" data-scrub data-scrub-y="32" data-scrub-opacity-from="0.2" data-scrub-scale="0.96" data-scrub-layer="0.1">
        <div class="new-arrivals-showcase__anchor-media">
          {%- if anchor_image != blank -%}
            {{
              anchor_image
              | image_url: width: 1200
              | image_tag:
                class: 'new-arrivals-showcase__anchor-image',
                widths: '400, 600, 900, 1200',
                loading: 'lazy',
                alt: anchor_alt
            }}
          {%- else -%}
            <div class="new-arrivals-showcase__anchor-placeholder" aria-hidden="true"></div>
          {%- endif -%}
        </div>

        <div class="new-arrivals-showcase__anchor-overlay"></div>
        <div class="new-arrivals-showcase__anchor-copy">
          <span class="new-arrivals-showcase__anchor-kicker">NEW COLLECTION</span>
          <h2 class="new-arrivals-showcase__anchor-title">{{ section_title }}</h2>
          {%- if section_subtitle != blank -%}
            <p class="new-arrivals-showcase__anchor-subtitle">{{ section_subtitle }}</p>
          {%- endif -%}
        </div>
      </a>

      <div class="new-arrivals-showcase__rail-shell" data-scrub data-scrub-y="20" data-scrub-opacity-from="0" data-scrub-from="0.1">
        <div class="new-arrivals-showcase__rail-toolbar">
          <div class="new-arrivals-showcase__rail-heading">
            <p class="new-arrivals-showcase__eyebrow">NEW COLLECTION</p>
            <p class="new-arrivals-showcase__support">Scroll through the latest Catfat additions.</p>
          </div>

          <div class="new-arrivals-showcase__controls" aria-label="New arrivals navigation">
            <button
              type="button"
              class="new-arrivals-showcase__arrow"
              data-arrivals-prev
              aria-controls="{{ carousel_id }}"
              aria-label="Scroll new arrivals left"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M14.5 6.5 9 12l5.5 5.5"></path>
              </svg>
            </button>
            <button
              type="button"
              class="new-arrivals-showcase__arrow"
              data-arrivals-next
              aria-controls="{{ carousel_id }}"
              aria-label="Scroll new arrivals right"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M9.5 6.5 15 12l-5.5 5.5"></path>
              </svg>
            </button>
          </div>
        </div>

        <div class="new-arrivals-showcase__rail" id="{{ carousel_id }}" data-arrivals-rail>
          {%- if arrivals_collection != blank and arrivals_collection.products.size > 0 -%}
            {%- for product in arrivals_collection.products limit: products_limit -%}
              {% render 'new-arrival-card', product: product %}
            {%- endfor -%}
          {%- else -%}
            {%- for index in (1..4) -%}
              <article class="new-arrivals-card new-arrivals-card--placeholder">
                <div class="new-arrivals-card__media new-arrivals-card__media--placeholder"></div>
                <div class="new-arrivals-card__body">
                  <div class="new-arrivals-card__rating new-arrivals-card__rating--placeholder"></div>
                  <div class="new-arrivals-card__title new-arrivals-card__title--placeholder"></div>
                  <div class="new-arrivals-card__swatches new-arrivals-card__swatches--placeholder"></div>
                  <div class="new-arrivals-card__price new-arrivals-card__price--placeholder"></div>
                </div>
              </article>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('new-arrivals-showcase-{{ section.id }}');
    if (!section) return;

    const rail = section.querySelector('[data-arrivals-rail]');
    const previousButton = section.querySelector('[data-arrivals-prev]');
    const nextButton = section.querySelector('[data-arrivals-next]');
    if (!rail || !previousButton || !nextButton) return;

    const getStep = () => {
      const card = rail.querySelector('.new-arrivals-card');
      if (!card) return rail.clientWidth * 0.85;

      const styles = window.getComputedStyle(rail);
      const gap = parseFloat(styles.gap || styles.columnGap || 0);
      return card.getBoundingClientRect().width + gap;
    };

    const syncButtons = () => {
      previousButton.disabled = rail.scrollLeft <= 4;
      nextButton.disabled = rail.scrollLeft + rail.clientWidth >= rail.scrollWidth - 4;
    };

    previousButton.addEventListener('click', () => {
      rail.scrollBy({ left: getStep() * -1, behavior: 'smooth' });
    });

    nextButton.addEventListener('click', () => {
      rail.scrollBy({ left: getStep(), behavior: 'smooth' });
    });

    rail.addEventListener('scroll', syncButtons, { passive: true });
    window.addEventListener('resize', syncButtons);
    syncButtons();
  })();
</script>

{% schema %}
{
  "name": "New Arrivals Showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "New Arrivals",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Fresh picks for everyday meals",
      "label": "Subtitle"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "image_picker",
      "id": "anchor_image",
      "label": "Anchor card image"
    },
    {
      "type": "text",
      "id": "anchor_image_alt",
      "default": "Catfat new arrivals in a school-day setting",
      "label": "Anchor image alt text"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "New Arrivals Showcase"
    }
  ]
}
{% endschema %}
