{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

<style>
.product {
  display: grid;
  gap: 3rem;
}

@media (min-width: 1024px) {
  .product {
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .product--right .product__media-wrapper {
    order: 2;
  }
}

/* Product Media */
.product__media-wrapper {
  position: relative;
}

.product__media-list {
  display: grid;
  gap: 15px;
}

.product__media-item {
  width: 100%;
  border-radius: 12px;
  overflow: hidden;
  background: #f5f5f5;
}

.product__media-item img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

/* Product Info */
.product__info-wrapper {
  padding: 0;
}

.product__title {
  font-size: 2.5rem;
  font-weight: 800;
  color: #333;
  margin: 0 0 1rem;
  line-height: 1.2;
}

.product__price {
  font-size: 1.8rem;
  font-weight: 700;
  color: #e84a7f;
  margin-bottom: 1.5rem;
}

.product__price .compare-at {
  font-size: 1.2rem;
  color: #999;
  text-decoration: line-through;
  margin-left: 10px;
}

/* Variant Selector */
.product__variants {
  margin-bottom: 1.5rem;
}

.product-variant {
  margin-bottom: 1.5rem;
}

.product-variant__label {
  font-size: 0.9rem;
  font-weight: 600;
  color: #333;
  margin-bottom: 0.5rem;
  display: block;
}

.product-variant__options {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.product-variant__option {
  padding: 10px 20px;
  border: 2px solid #ddd;
  border-radius: 8px;
  background: #fff;
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 0.9rem;
}

.product-variant__option:hover {
  border-color: #ff6b9d;
}

.product-variant__option.selected {
  border-color: #ff6b9d;
  background: #ff6b9d;
  color: #fff;
}

.product-variant__option.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Color Swatches */
.product-variant__option.color-swatch {
  width: 40px;
  height: 40px;
  padding: 0;
  border-radius: 50%;
  border: 3px solid transparent;
}

.product-variant__option.color-swatch.selected {
  border-color: #333;
}

/* Quantity Selector */
.product__quantity {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 1.5rem;
}

.quantity-selector {
  display: flex;
  align-items: center;
  border: 2px solid #ddd;
  border-radius: 8px;
  overflow: hidden;
}

.quantity-selector__btn {
  width: 45px;
  height: 45px;
  border: none;
  background: #f5f5f5;
  cursor: pointer;
  font-size: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quantity-selector__btn:hover {
  background: #eee;
}

.quantity-selector__input {
  width: 60px;
  height: 45px;
  border: none;
  text-align: center;
  font-size: 1rem;
  font-weight: 600;
}

/* Add to Cart Button */
.product-form__submit {
  width: 100%;
  padding: 1.2rem 2rem;
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  color: white;
  border: none;
  border-radius: 50px;
  font-size: 1.1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(255, 107, 157, 0.4);
}

.product-form__submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(255, 107, 157, 0.5);
}

.product-form__submit:disabled {
  background: #ccc;
  cursor: not-allowed;
  box-shadow: none;
}

/* Product Description */
.product__description {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid #eee;
}

.product__description h3 {
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 1rem;
  color: #333;
}

.product__description p {
  color: #666;
  line-height: 1.7;
}

/* Product Meta */
.product__meta {
  margin-top: 1.5rem;
  font-size: 0.9rem;
  color: #888;
}

.product__meta p {
  margin: 0.3rem 0;
}

/* Mobile */
@media (max-width: 768px) {
  .product__title {
    font-size: 1.8rem;
  }

  .product__price {
    font-size: 1.4rem;
  }
}
</style>

<div class="product product--large product--{{ section.settings.media_position }} page-width">
  <!-- Product Media -->
  <div class="product__media-wrapper">
    <div class="product__media-list">
      {%- if product.featured_media != blank -%}
        <div class="product__media-item">
          {{ product.featured_media | image_url: width: 1200 | image_tag: loading: 'lazy', alt: product.title }}
        </div>
      {%- else -%}
        <div class="product__media-item">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- for media in product.media -%}
        {%- if media.id != product.featured_media.id -%}
          <div class="product__media-item">
            {{ media | image_url: width: 1200 | image_tag: loading: 'lazy', alt: media.alt }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Product Info -->
  <div class="product__info-wrapper">
    <h1 class="product__title">{{ product.title | escape }}</h1>

    <div class="product__price">
      {%- if product.price_varies -%}
        From {{ product.price | money }}
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
      {%- if product.compare_at_price > product.price -%}
        <span class="compare-at">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    {%- form 'product', product, id: 'product-form', class: 'product-form' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      <!-- Variant Selectors -->
      {%- if product.variants.size > 1 -%}
        {%- for option in product.options_with_values -%}
          <div class="product-variant">
            <label class="product-variant__label">{{ option.name }}: <span id="selected-{{ option.name | downcase }}">{{ option.selected_value }}</span></label>
            <div class="product-variant__options">
              {%- for value in option.values -%}
                <button type="button"
                  class="product-variant__option{% if value == option.selected_value %} selected{% endif %}"
                  data-option-name="{{ option.name }}"
                  data-option-value="{{ value }}"
                  onclick="selectVariant('{{ option.name }}', '{{ value }}')">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

      <!-- Quantity Selector -->
      <div class="product__quantity">
        <label class="product-variant__label">Quantity:</label>
        <div class="quantity-selector">
          <button type="button" class="quantity-selector__btn" onclick="updateQuantity(-1)">-</button>
          <input type="number" name="quantity" value="1" min="1" class="quantity-selector__input" id="quantity-input">
          <button type="button" class="quantity-selector__btn" onclick="updateQuantity(1)">+</button>
        </div>
      </div>

      <!-- Add to Cart -->
      <button type="submit" name="add" class="product-form__submit"{% unless product.selected_or_first_available_variant.available %} disabled{% endunless %}>
        {%- if product.selected_or_first_available_variant.available -%}
          Add to Cart - {{ product.price | money }}
        {%- else -%}
          Sold Out
        {%- endif -%}
      </button>
    {%- endform -%}

    <!-- WhatsApp Share Button -->
    <div class="product-whatsapp-share">
      <a href="https://api.whatsapp.com/send?phone=918383013068&text=Hi%20CatFat,%20I'm%20interested%20in%20{{ product.title | url_encode }}%20-%20{{ product.price | money | url_encode }}%20%0A%0A{{ request.origin }}{{ product.url | url_encode }}" class="whatsapp-share-btn" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Ask on WhatsApp - {{ product.price | money }}
      </a>
    </div>

    <style>
      .product-whatsapp-share {
        margin-top: 15px;
      }
      .whatsapp-share-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        padding: 14px 20px;
        background: #25D366;
        color: white;
        text-decoration: none;
        border-radius: 30px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
      }
      .whatsapp-share-btn:hover {
        background: #128C7E;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
      }
    </style>

    <!-- Product Meta -->
    <div class="product__meta">
      {%- if product.vendor != blank -%}
        <p><strong>Brand:</strong> {{ product.vendor }}</p>
      {%- endif -%}
      <p><strong>SKU:</strong> {{ product.selected_or_first_available_variant.sku | default: 'N/A' }}</p>
      {%- if product.tags.size > 0 -%}
        <p><strong>Tags:</strong> {{ product.tags | join: ', ' }}</p>
      {%- endif -%}
    </div>

    <!-- Product Description -->
    {%- if product.description != blank -%}
      <div class="product__description">
        <h3>Product Description</h3>
        <div class="rte">{{ product.description }}</div>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
function selectVariant(optionName, value) {
  // Update button states
  document.querySelectorAll('[data-option-name="' + optionName + '"]').forEach(btn => {
    btn.classList.toggle('selected', btn.dataset.optionValue === value);
  });

  // Update label
  document.getElementById('selected-' + optionName.toLowerCase()).textContent = value;

  // Find matching variant
  const form = document.getElementById('product-form');
  const variantInputs = form.querySelectorAll('input[name="id"]');

  // Build variant query
  const optionMap = {};
  document.querySelectorAll('.product-variant__option.selected').forEach(btn => {
    optionMap[btn.dataset.optionName] = btn.dataset.optionValue;
  });

  // Find matching variant
  {% for variant in product.variants %}
    if (
      {% for option in product.options_with_values %}
        optionMap['{{ option.name }}'] === '{{ variant.options[forloop.index0] }}'{% unless forloop.last %} && {% endunless %}
      {% endfor %}
    ) {
      variantInputs[0].value = {{ variant.id }};
    }
  {% endfor %}
}

function updateQuantity(change) {
  const input = document.getElementById('quantity-input');
  let value = parseInt(input.value) + change;
  if (value < 1) value = 1;
  input.value = value;
}
</script>

{% schema %}
{
  "name": "Product page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Media position"
    }
  ]
}
{% endschema %}
