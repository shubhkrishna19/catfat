<!-- T-P001: Sticky Add to Cart Bar -->
<div class="sticky-add-to-cart" id="stickyAddToCart">
  <div class="sticky-add-to-cart__product">
    {%- if product.featured_media != blank -%}
      <img src="{{ product.featured_media | image_url: width: 100 }}" alt="{{ product.title }}" class="sticky-add-to-cart__image">
    {%- else -%}
      <div class="sticky-add-to-cart__image"></div>
    {%- endif -%}
    <div class="sticky-add-to-cart__info">
      <h4>{{ product.title }}</h4>
      <span class="sticky-add-to-cart__price">{{ product.price | money }}</span>
    </div>
  </div>
  <div class="sticky-add-to-cart__actions">
    <div class="sticky-add-to-cart__qty">
      <button type="button" onclick="updateStickyQuantity(-1)">-</button>
      <span id="sticky-qty">1</span>
      <button type="button" onclick="updateStickyQuantity(1)">+</button>
    </div>
    <button type="button" class="sticky-add-to-cart__btn" onclick="stickyAddToCart()">Add to Cart</button>
  </div>
</div>

<script>
function selectVariant(optionName, value) {
  // Update button states
  document.querySelectorAll('[data-option-name="' + optionName + '"]').forEach(btn => {
    btn.classList.toggle('selected', btn.dataset.optionValue === value);
  });

  // Update label
  document.getElementById('selected-' + optionName.toLowerCase()).textContent = value;

  // Find matching variant
  const form = document.getElementById('product-form');
  const variantInputs = form.querySelectorAll('input[name="id"]');

  // Build variant query
  const optionMap = {};
  document.querySelectorAll('.product-variant__option.selected').forEach(btn => {
    optionMap[btn.dataset.optionName] = btn.dataset.optionValue;
  });

  // Find matching variant
  {% for variant in product.variants %}
    if (
      {% for option in product.options_with_values %}
        optionMap['{{ option.name }}'] === '{{ variant.options[forloop.index0] }}'{% unless forloop.last %} && {% endunless %}
      {% endfor %}
    ) {
      variantInputs[0].value = {{ variant.id }};
    }
  {% endfor %}
}

function updateQuantity(change) {
  const input = document.getElementById('quantity-input');
  let value = parseInt(input.value) + change;
  if (value < 1) value = 1;
  input.value = value;
  
  // Sync with sticky bar
  document.getElementById('sticky-qty').textContent = value;
}

// ========== T-P001: Sticky Add to Cart Bar Functions ==========
let stickyQty = 1;

function updateStickyQuantity(change) {
  stickyQty += change;
  if (stickyQty < 1) stickyQty = 1;
  document.getElementById('sticky-qty').textContent = stickyQty;
}

function stickyAddToCart() {
  const form = document.getElementById('product-form');
  const qtyInput = form.querySelector('input[name="quantity"]');
  qtyInput.value = stickyQty;
  
  // Submit the form
  fetch(window.Shopify.routes.root + 'cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      items: [{ id: form.querySelector('input[name="id"]').value, quantity: stickyQty }]
    })
  })
  .then(response => response.json())
  .then(data => {
    alert('Added to cart!');
    // Optionally update cart count
    if (typeof updateCartCount === 'function') updateCartCount();
  })
  .catch(error => console.error('Error:', error));
}

// Show/hide sticky bar on scroll
let lastScroll = 0;
window.addEventListener('scroll', function() {
  const stickyBar = document.getElementById('stickyAddToCart');
  const currentScroll = window.pageYOffset;
  
  if (currentScroll > 500) {
    stickyBar.classList.add('visible');
  } else {
    stickyBar.classList.remove('visible');
  }
  
  lastScroll = currentScroll;
});

// ========== T-P002: Size Guide Modal Functions ==========
function openSizeGuide() {
  document.getElementById('sizeGuideModal').classList.add('active');
}

function closeSizeGuide() {
  document.getElementById('sizeGuideModal').classList.remove('active');
}

// Close modal on outside click
document.getElementById('sizeGuideModal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeSizeGuide();
  }
});

// ========== T-P003: Real-time Inventory Counter ==========
// Inventory updates would come from Shopify's inventory API
// This is a client-side simulation

// ========== T-P004: Bundle Savings Calculator Functions ==========
function updateBundlePrice() {
  let total = 0;
  const checkboxes = document.querySelectorAll('.bundle-savings__items input[type="checkbox"]');
  
  checkboxes.forEach(cb => {
    if (cb.checked) {
      total += parseFloat(cb.dataset.price) || 0;
    }
  });
  
  const discount = total * 0.10;
  const final = total - discount;
  
  document.getElementById('bundle-subtotal').textContent = '₹' + total.toFixed(0);
  document.getElementById('bundle-discount').textContent = '-₹' + discount.toFixed(0);
  document.getElementById('bundle-total').textContent = '₹' + final.toFixed(0);
}

function addBundleToCart() {
  const checkboxes = document.querySelectorAll('.bundle-savings__items input[type="checkbox"]:checked');
  const items = [];
  
  checkboxes.forEach(cb => {
    if (cb.dataset.id && cb.dataset.id !== '0') {
      items.push({ id: parseInt(cb.dataset.id), quantity: 1 });
    }
  });
  
  if (items.length === 0) {
    alert('Please select at least the main product');
    return;
  }
  
  fetch(window.Shopify.routes.root + 'cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: items })
  })
  .then(response => response.json())
  .then(data => {
    alert('Bundle added to cart!');
  })
  .catch(error => console.error('Error:', error));
}

// ========== T-P005: Frequently Bought Together Functions ==========
document.querySelectorAll('.fbt-product input').forEach(cb => {
  cb.addEventListener('change', updateFBTPrice);
});

function updateFBTPrice() {
  let total = {{ product.price | money_without_currency | default: 0 }};
  
  document.querySelectorAll('.fbt-product input:checked').forEach(cb => {
    total += parseFloat(cb.dataset.price) || 0;
  });
  
  document.getElementById('fbt-total').textContent = '₹' + total.toFixed(0);
}

function addFBTToCart() {
  const items = [];
  
  // Add main product
  const form = document.getElementById('product-form');
  items.push({ id: parseInt(form.querySelector('input[name="id"]').value), quantity: 1 });
  
  // Add selected FBT products (in production, these would have variant IDs)
  document.querySelectorAll('.fbt-product input:checked').forEach(cb => {
    // In production, you'd have actual variant IDs from metafields
    // For demo, we'll just alert the user
  });
  
  fetch(window.Shopify.routes.root + 'cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: items })
  })
  .then(response => response.json())
  .then(data => {
    alert('Added to cart!');
  })
  .catch(error => console.error('Error:', error));
}
</script>

