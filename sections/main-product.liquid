{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign compare_at_price = current_variant.compare_at_price | default: product.compare_at_price_max
  if compare_at_price < current_variant.price
    assign compare_at_price = product.compare_at_price_max
  endif

  assign theme_count = 0
  assign color_count = 0
  assign style_count = 0
  assign option_summary = blank
  assign product_text = product.title | append: ' ' | append: product.description | strip_html | downcase

  for option in product.options_with_values
    assign option_name = option.name | strip | downcase
    if option_name contains 'theme'
      assign theme_count = option.values.size
    elsif option_name contains 'color' or option_name contains 'colour'
      assign color_count = option.values.size
    elsif option_name contains 'style' or option_name contains 'personal' or option_name contains 'engraving'
      assign style_count = option.values.size
    endif
  endfor

  if theme_count > 0
    assign option_summary = theme_count | append: ' theme choices'
  elsif color_count > 0
    assign option_summary = color_count | append: ' color choices'
  elsif product.variants.size > 1
    assign option_summary = product.variants.size | append: ' buying options'
  endif

  assign eyebrow = 'Catfat product'
  if product_text contains 'vacuum' or product_text contains 'insulated'
    assign eyebrow = 'Insulated favourite'
  elsif product_text contains 'microwave'
    assign eyebrow = 'Microwave-safe pick'
  elsif product_text contains 'stainless'
    assign eyebrow = 'Stainless steel build'
  elsif theme_count > 0
    assign eyebrow = 'Character-led pick'
  endif

  assign summary_text = product.description | strip_html | strip | truncate: 220
  if summary_text == blank
    assign summary_text = 'Playful lunchware designed for school days, gifting, and everyday carry.'
  endif

  assign feature_one = 'Original product images from the live Catfat catalog.'
  assign feature_two = 'Cleaner variant selection flow for faster buying decisions.'
  assign feature_three = 'Secure add-to-cart flow tied to the active variant.'
  assign has_legacy_review_widget = false
  assign has_review_data = false

  if product_text contains 'insulated' or product_text contains 'vacuum'
    assign feature_one = 'Insulated design made for stronger temperature hold on the go.'
  elsif product_text contains 'microwave'
    assign feature_one = 'Microwave-safe convenience for practical school lunches.'
  elsif product_text contains 'leak' or product_text contains 'spill'
    assign feature_one = 'Leak-resistant build for calmer bags and easier mornings.'
  elsif product_text contains 'stainless'
    assign feature_one = 'Food-grade stainless steel suited for everyday school use.'
  endif

  if product_text contains 'spoon'
    assign feature_two = 'Built-in spoon support for quick lunch and snack breaks.'
  elsif theme_count > 0
    assign feature_two = theme_count | append: ' character themes available on this product.'
  elsif color_count > 0
    assign feature_two = color_count | append: ' color options available on this product.'
  endif

  if style_count > 1
    assign feature_three = style_count | append: ' style variants available for this listing.'
  endif

  if product.metafields.judgeme.widget.size > 20
    assign has_legacy_review_widget = true
    assign has_review_data = true
  endif

  if product.metafields.reviews.rating_count > 0
    assign has_review_data = true
  endif

  assign savings_amount = 0
  assign savings_percent = 0
  if compare_at_price > current_variant.price and compare_at_price != blank
    assign savings_amount = compare_at_price | minus: current_variant.price
    assign savings_percent = savings_amount | times: 100 | divided_by: compare_at_price
  endif

  assign main_image_id = 'CatfatProductMainImage-' | append: section.id
  assign form_id = 'CatfatProductForm-' | append: section.id
  assign current_variant_title = current_variant.title | default: product.title
  if current_variant_title == 'Default Title'
    assign current_variant_title = product.title
  endif
-%}

<section class="catfat-product page-width" data-product-section-id="{{ section.id }}">
  <div class="catfat-product__layout catfat-product__layout--{{ section.settings.media_position }}">
    <div class="catfat-product__media-column">
      <div class="catfat-product__stage-shell">
        <div class="catfat-product__stage">
          {%- assign stage_media = current_variant.featured_media | default: product.featured_media | default: product.media.first -%}
          {%- if stage_media != blank -%}
            {{
              stage_media
              | image_url: width: 1600
              | image_tag:
                id: main_image_id,
                class: 'catfat-product__stage-image',
                widths: '480, 720, 960, 1280, 1600',
                loading: 'eager',
                alt: product.title
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'catfat-product__stage-image placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="catfat-product__thumbs" role="list">
            {%- for media in product.media -%}
              {%- if media.media_type == 'image' -%}
                <button
                  type="button"
                  class="catfat-product__thumb{% if stage_media != blank and media.id == stage_media.id %} is-active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-src="{{ media | image_url: width: 1600 }}"
                  data-media-alt="{{ media.alt | default: product.title | escape }}"
                  aria-label="View image {{ forloop.index }}"
                  aria-pressed="{% if stage_media != blank and media.id == stage_media.id %}true{% else %}false{% endif %}"
                >
                  {{
                    media
                    | image_url: width: 240
                    | image_tag:
                      class: 'catfat-product__thumb-image',
                      widths: '90, 120, 180, 240',
                      loading: 'lazy',
                      alt: media.alt | default: product.title
                  }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="catfat-product__media-meta">
          <span class="catfat-product__media-caption">
            {% if product.media.size > 1 %}Tap a thumbnail to switch the main product photo instantly.{% else %}Original product photo from the live Catfat catalog.{% endif %}
          </span>
          <span class="catfat-product__media-count" data-media-count>
            Image 1 of {% if product.media.size > 0 %}{{ product.media.size }}{% else %}1{% endif %}
          </span>
        </div>
      </div>
    </div>

    <div class="catfat-product__info-column">
      <div class="catfat-product__panel">
        <div class="catfat-product__heading">
          <span class="catfat-product__eyebrow">{{ eyebrow }}</span>
          {%- if option_summary != blank -%}
            <span class="catfat-product__option-summary">{{ option_summary }}</span>
          {%- endif -%}
        </div>

        <h1 class="catfat-product__title">{{ product.title | escape }}</h1>

        {%- if has_review_data -%}
          <div class="catfat-product__review-summary">
            <!-- Start of Judge.me code -->
            <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}'>
              {{ product.metafields.judgeme.badge }}
            </div>
            <!-- End of Judge.me code -->

            {%- if product.metafields.reviews.rating_count > 0 -%}
              <span class="catfat-product__review-copy">
                Rated {{ product.metafields.reviews.rating.value }} / {{ product.metafields.reviews.rating.value.scale_max }}
                from {{ product.metafields.reviews.rating_count }} review{% if product.metafields.reviews.rating_count != 1 %}s{% endif %}.
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="catfat-product__price-row">
          <div class="catfat-product__price-stack">
            <span class="catfat-product__price" data-product-price>
              {%- if product.price_varies -%}
                From {{ product.price_min | money }}
              {%- else -%}
                {{ current_variant.price | money }}
              {%- endif -%}
            </span>
            <span class="catfat-product__compare{% unless compare_at_price > current_variant.price %} is-hidden{% endunless %}" data-product-compare>
              {{ compare_at_price | money }}
            </span>
          </div>

          <div class="catfat-product__deal{% unless savings_percent > 0 %} is-hidden{% endunless %}" data-product-deal>
            <strong data-product-savings-percent>{{ savings_percent }}% off</strong>
            <span data-product-savings-amount>You save {{ savings_amount | money }}</span>
          </div>
        </div>

        <div class="catfat-product__selection-bar">
          <span class="catfat-product__selection-label">Current selection</span>
          <strong class="catfat-product__selection-value" data-current-variant-title>{{ current_variant_title }}</strong>
        </div>

        <p class="catfat-product__summary">{{ summary_text }}</p>

        <div class="catfat-product__trust-grid">
          <div class="catfat-product__trust-card">{{ feature_one }}</div>
          <div class="catfat-product__trust-card">{{ feature_two }}</div>
          <div class="catfat-product__trust-card">{{ feature_three }}</div>
        </div>

        <div class="catfat-product__service-strip">
          <div class="catfat-product__service-item">
            <strong>Original photos</strong>
            <span>Catalog imagery shown before checkout.</span>
          </div>
          <div class="catfat-product__service-item">
            <strong>Need gifting help?</strong>
            <span>Use the bulk gifting lane for faster shortlist decisions.</span>
          </div>
          <a href="/collections/corporate-gifting-bulk-gifting" class="catfat-product__service-link">
            Explore bulk gifting
          </a>
        </div>

        {%- form 'product', product, id: form_id, class: 'catfat-product__form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

          {%- for option in product.options_with_values -%}
            <fieldset class="catfat-product__option-group">
              <legend class="catfat-product__option-label">{{ option.name | strip }}</legend>
              <div class="catfat-product__option-values">
                {%- for value in option.values -%}
                  {%- assign option_index = forloop.parentloop.index0 -%}
                  {%- assign input_id = 'CatfatOption-' | append: section.id | append: '-' | append: option_index | append: '-' | append: forloop.index0 -%}
                  <input
                    type="radio"
                    class="catfat-product__option-input"
                    name="option-{{ option.position }}"
                    id="{{ input_id }}"
                    value="{{ value | escape }}"
                    data-option-index="{{ option_index }}"
                    {% if current_variant.options[option_index] == value %}checked{% endif %}
                  >
                  <label class="catfat-product__option-chip" for="{{ input_id }}">
                    {{ value }}
                  </label>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- endfor -%}

          {%- if product.options_with_values.size > 0 -%}
            <p class="catfat-product__option-helper">Choose a theme, color, or style and the matching product details update with it.</p>
          {%- endif -%}

          <div class="catfat-product__purchase-row">
            <div class="catfat-product__quantity-shell">
              <span class="catfat-product__quantity-label">Qty</span>
              <div class="catfat-product__quantity">
                <button type="button" class="catfat-product__qty-button" data-qty-decrease aria-label="Decrease quantity">-</button>
                <input type="number" class="catfat-product__qty-input" name="quantity" value="1" min="1" data-qty-input>
                <button type="button" class="catfat-product__qty-button" data-qty-increase aria-label="Increase quantity">+</button>
              </div>
            </div>

            <button
              type="submit"
              name="add"
              class="catfat-product__submit"
              {% unless current_variant.available %}disabled{% endunless %}
              data-submit-button
            >
              {% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}
            </button>
          </div>

          <p class="catfat-product__variant-status{% if current_variant.available %} is-available{% endif %}" data-variant-status>
            {% if current_variant.available %}
              Variant selected and ready to add.
            {% else %}
              This combination is currently unavailable. Choose another option.
            {% endif %}
          </p>
        {%- endform -%}

        <div class="catfat-product__details-card">
          <div class="catfat-product__details-head">
            <h2 class="catfat-product__details-title">Product details</h2>
            {%- if product.vendor != blank -%}
              <span class="catfat-product__vendor">{{ product.vendor }}</span>
            {%- endif -%}
          </div>

        <div class="catfat-product__details-content rte">
          {{ product.description }}
        </div>
      </div>

      <div class="catfat-product__reviews-card">
        <div class="catfat-product__details-head">
          <h2 class="catfat-product__details-title">Customer reviews</h2>
          {%- if product.metafields.reviews.rating_count > 0 -%}
            <span class="catfat-product__vendor">
              {{ product.metafields.reviews.rating_count }} review{% if product.metafields.reviews.rating_count != 1 %}s{% endif %}
            </span>
          {%- endif -%}
        </div>

        <p class="catfat-product__reviews-intro">
          Real Catfat buyer feedback collected on the store and shown here where the buying decision happens.
        </p>

        <!-- Start of Judge.me code -->
        <div style='clear:both'></div>
        <div
          id='judgeme_product_reviews'
          class='jdgm-widget jdgm-review-widget'
          data-product-title='{{ product.title | escape }}'
          data-id='{{ product.id }}'
          data-product-id='{{ product.id }}'
          data-widget='review'
          data-auto-install='false'
          data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}'
          data-entry-point='review_widget.js'
          data-entry-key='review-widget/main.js'
        >
          {% if has_legacy_review_widget %}
            <div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>
          {% endif %}
        </div>
        {% if product.metafields.judgeme.review_widget_data %}
          <script>
            window.jdgm = window.jdgm || {};
            window.jdgm.data = window.jdgm.data || {};
            window.jdgm.data.reviewWidget = window.jdgm.data.reviewWidget || {};
            window.jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }};
          </script>
        {% endif %}
        <!-- End of Judge.me code -->
      </div>
    </div>
  </div>
  </div>

  <script type="application/json" id="CatfatProductData-{{ section.id }}">
    {{ product | json }}
  </script>

  <script>
    (() => {
      const root = document.querySelector('.catfat-product[data-product-section-id="{{ section.id }}"]');
      if (!root) return;

      const dataNode = document.getElementById('CatfatProductData-{{ section.id }}');
      if (!dataNode) return;

      const productData = JSON.parse(dataNode.textContent);
      const form = document.getElementById('{{ form_id }}');
      if (!form) return;

      const priceNode = root.querySelector('[data-product-price]');
      const compareNode = root.querySelector('[data-product-compare]');
      const dealNode = root.querySelector('[data-product-deal]');
      const savingsPercentNode = root.querySelector('[data-product-savings-percent]');
      const savingsAmountNode = root.querySelector('[data-product-savings-amount]');
      const variantInput = root.querySelector('[data-variant-id-input]');
      const submitButton = root.querySelector('[data-submit-button]');
      const statusNode = root.querySelector('[data-variant-status]');
      const qtyInput = root.querySelector('[data-qty-input]');
      const mediaCountNode = root.querySelector('[data-media-count]');
      const currentVariantTitleNode = root.querySelector('[data-current-variant-title]');
      const mainImage = document.getElementById('{{ main_image_id }}');
      const thumbButtons = Array.from(root.querySelectorAll('.catfat-product__thumb'));
      const optionInputs = Array.from(root.querySelectorAll('.catfat-product__option-input'));

      const money = (cents) => {
        const value = Number(cents || 0) / 100;
        return `Rs. ${value.toFixed(2)}`;
      };

      const getVariantLabel = (variant) => {
        if (!variant || !variant.title || variant.title === 'Default Title') return productData.title;
        return variant.title;
      };

      const animateMainImage = () => {
        if (!mainImage) return;
        mainImage.classList.add('is-switching');
        window.clearTimeout(mainImage._catfatSwitchTimer);
        mainImage._catfatSwitchTimer = window.setTimeout(() => {
          mainImage.classList.remove('is-switching');
        }, 220);
      };

      const setActiveThumb = (mediaId) => {
        let activeIndex = -1;

        thumbButtons.forEach((thumb, index) => {
          const isActive = String(thumb.dataset.mediaId) === String(mediaId);
          thumb.classList.toggle('is-active', isActive);
          thumb.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          if (isActive) activeIndex = index;
        });

        if (mediaCountNode && activeIndex >= 0) {
          mediaCountNode.textContent = `Image ${activeIndex + 1} of ${thumbButtons.length}`;
        }
      };

      const setImageFromMediaId = (mediaId) => {
        if (!mainImage || !mediaId) return;
        const thumb = thumbButtons.find((item) => String(item.dataset.mediaId) === String(mediaId));
        if (!thumb) return;
        animateMainImage();
        mainImage.src = thumb.dataset.mediaSrc;
        mainImage.srcset = '';
        mainImage.alt = thumb.dataset.mediaAlt || productData.title;
        setActiveThumb(mediaId);
      };

      const getSelectedOptions = () => {
        const selected = [];
        optionInputs.forEach((input) => {
          const index = Number(input.dataset.optionIndex);
          if (input.checked) selected[index] = input.value;
        });
        return selected;
      };

      const findVariant = () => {
        const selected = getSelectedOptions();
        return productData.variants.find((variant) => {
          return variant.options.every((optionValue, index) => optionValue === selected[index]);
        });
      };

      const renderVariant = (variant) => {
        if (!variant) return;

        variantInput.value = variant.id;
        priceNode.textContent = money(variant.price);

        if (currentVariantTitleNode) {
          currentVariantTitleNode.textContent = getVariantLabel(variant);
        }

        const compareAt = Number(variant.compare_at_price || 0);
        const price = Number(variant.price || 0);

        if (compareAt > price) {
          compareNode.textContent = money(compareAt);
          compareNode.classList.remove('is-hidden');
          const savings = compareAt - price;
          const percent = Math.round((savings * 100) / compareAt);
          savingsPercentNode.textContent = `${percent}% off`;
          savingsAmountNode.textContent = `You save ${money(savings)}`;
          dealNode.classList.remove('is-hidden');
        } else {
          compareNode.classList.add('is-hidden');
          dealNode.classList.add('is-hidden');
        }

        if (variant.available) {
          submitButton.disabled = false;
          submitButton.textContent = 'Add to cart';
          statusNode.textContent = 'Variant selected and ready to add.';
          statusNode.classList.add('is-available');
        } else {
          submitButton.disabled = true;
          submitButton.textContent = 'Sold out';
          statusNode.textContent = 'This combination is currently unavailable. Choose another option.';
          statusNode.classList.remove('is-available');
        }

        if (variant.featured_media && variant.featured_media.id) {
          setImageFromMediaId(variant.featured_media.id);
        }

        if (window.history && window.history.replaceState) {
          const url = new URL(window.location.href);
          url.searchParams.set('variant', variant.id);
          window.history.replaceState({}, '', url.toString());
        }
      };

      optionInputs.forEach((input) => {
        input.addEventListener('change', () => {
          const variant = findVariant();
          renderVariant(variant);
        });
      });

      thumbButtons.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          if (!mainImage) return;
          setImageFromMediaId(thumb.dataset.mediaId);
        });
      });

      if (thumbButtons.length > 0) {
        const activeThumb = thumbButtons.find((thumb) => thumb.classList.contains('is-active')) || thumbButtons[0];
        setActiveThumb(activeThumb.dataset.mediaId);
      }

      const decrease = root.querySelector('[data-qty-decrease]');
      const increase = root.querySelector('[data-qty-increase]');

      if (decrease && qtyInput) {
        decrease.addEventListener('click', () => {
          qtyInput.value = Math.max(1, Number(qtyInput.value || 1) - 1);
        });
      }

      if (increase && qtyInput) {
        increase.addEventListener('click', () => {
          qtyInput.value = Math.max(1, Number(qtyInput.value || 1) + 1);
        });
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "Product page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Media position"
    }
  ]
}
{% endschema %}
