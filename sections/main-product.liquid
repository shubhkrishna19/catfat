    <!-- T-P004: Bundle Savings Calculator -->
    {%- assign related_products = collections['all'].products | slice: 0, 3 -%}
    {%- if related_products.size > 0 -%}
    <div class="bundle-savings">
      <div class="bundle-savings__title">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        Complete the Look - Save 10%!
      </div>
      <div class="bundle-savings__items">
        <!-- Current Product -->
        <label class="bundle-item">
          <input type="checkbox" checked data-price="{{ product.price | money_without_currency }}" data-id="{{ product.selected_or_first_available_variant.id }}" onchange="updateBundlePrice()">
          {%- if product.featured_media != blank -%}
            <img src="{{ product.featured_media | image_url: width: 100 }}" alt="{{ product.title }}" class="bundle-item__image">
          {%- else -%}
            <div class="bundle-item__image"></div>
          {%- endif -%}
          <div class="bundle-item__info">
            <div class="bundle-item__name">{{ product.title }}</div>
            <div class="bundle-item__price">{{ product.price | money }}</div>
          </div>
        </label>
        
        <!-- Sample Related Products (would come from metafields or collections in production) -->
        <label class="bundle-item">
          <input type="checkbox" data-price="299" data-id="0" onchange="updateBundlePrice()">
          <div class="bundle-item__image" style="background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; color: #999;">Add-on</div>
          <div class="bundle-item__info">
            <div class="bundle-item__name">Kids Socks Set</div>
            <div class="bundle-item__price">₹299</div>
          </div>
        </label>
        
        <label class="bundle-item">
          <input type="checkbox" data-price="199" data-id="0" onchange="updateBundlePrice()">
          <div class="bundle-item__image" style="background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; color: #999;">Add-on</div>
          <div class="bundle-item__info">
            <div class="bundle-item__name">Gift Wrap</div>
            <div class="bundle-item__price">₹199</div>
          </div>
        </label>
      </div>
      <div class="bundle-savings__total">
        <div class="bundle-savings__subtotal">
          <span>Subtotal:</span>
          <span id="bundle-subtotal">{{ product.price | money }}</span>
        </div>
        <div class="bundle-savings__discount">
          <span>Bundle Discount (10%):</span>
          <span id="bundle-discount">-₹0</span>
        </div>
        <div class="bundle-savings__final">
          <span>Bundle Total:</span>
          <span id="bundle-total">{{ product.price | money }}</span>
        </div>
        <button type="button" class="bundle-savings__btn" onclick="addBundleToCart()">Add Bundle to Cart</button>
      </div>
    </div>
    {%- endif -%}

    <!-- T-P005: Frequently Bought Together -->
    <div class="frequently-bought">
      <h3 class="frequently-bought__title">Frequently Bought Together</h3>
      <div class="frequently-bought__items">
        <!-- Sample FBT products -->
        <label class="fbt-product">
          <input type="checkbox" checked data-price="199">
          <img src="https://placehold.co/150x150/f5f5f5/999?text=Item" alt="Accessory" class="fbt-product__image">
          <div class="fbt-product__name">Matching Hair Accessory</div>
          <div class="fbt-product__price">₹199</div>
        </label>
        
        <label class="fbt-product">
          <input type="checkbox" data-price="149">
          <img src="https://placehold.co/150x150/f5f5f5/999?text=Item" alt="Care Kit" class="fbt-product__image">
          <div class="fbt-product__name">Premium Care Kit</div>
          <div class="fbt-product__price">₹149</div>
        </label>
        
        <label class="fbt-product">
          <input type="checkbox" data-price="99">
          <img src="https://placehold.co/150x150/f5f5f5/999?text=Item" alt="Sticker Set" class="fbt-product__image">
          <div class="fbt-product__name">Fun Sticker Set</div>
          <div class="fbt-product__price">₹99</div>
        </label>
      </div>
      <div class="fbt-total">
        <div class="fbt-total__price">
          <span class="fbt-total__label">Total (with selected):</span>
          <span class="fbt-total__amount" id="fbt-total">{{ product.price | plus: 199 | money }}</span>
        </div>
        <button type="button" class="fbt-add-btn" onclick="addFBTToCart()">Add Selected to Cart</button>
