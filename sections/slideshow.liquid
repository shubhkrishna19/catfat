{{ 'section-marketplace-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign catalog_collection = collections['all-products']
  assign lunch_collection = collections['lunch-box']
  assign bottle_collection = collections['bottles-flasks']
  assign kids_collection = collections['kids-collections']
  assign gifting_collection = collections['corporate-gifting-bulk-gifting']
  assign all_reviews_count = shop.metafields.judgeme.all_reviews_count | default: '650' | plus: 0

  assign main_collection = lunch_collection
  if main_collection == blank
    assign main_collection = kids_collection
  endif

  assign main_product = blank
  if main_collection != blank
    for product in main_collection.products
      if product.available
        assign main_product = product
        break
      endif
    endfor
    if main_product == blank
      assign main_product = main_collection.products.first
    endif
  endif

  assign kids_product = blank
  if kids_collection != blank
    for product in kids_collection.products
      if product.available
        assign kids_product = product
        break
      endif
    endfor
    if kids_product == blank
      assign kids_product = kids_collection.products.first
    endif
  endif

  assign bottle_product = blank
  if bottle_collection != blank
    for product in bottle_collection.products
      if product.available
        assign bottle_product = product
        break
      endif
    endfor
    if bottle_product == blank
      assign bottle_product = bottle_collection.products.first
    endif
  endif

-%}

<section
  class="marketplace-hero{% if section.settings.auto_rotate %} marketplace-hero--animated{% endif %}"
  style="--marketplace-float-speed: {{ section.settings.change_slides_speed }}s;"
>
  <div class="page-width">
    <div class="marketplace-hero__shell">
      <div class="marketplace-hero__copy">
        <span class="marketplace-hero__eyebrow">Catfat lunchware</span>
        <h2 class="marketplace-hero__title">Packed for school smiles.</h2>
        <p class="marketplace-hero__description">
          Explore Catfat lunch boxes, bottles, and gifting picks through a cleaner homepage built to help parents compare faster and buy with more confidence.
        </p>

        <div class="marketplace-hero__actions">
          <a
            href="{% if lunch_collection != blank %}{{ lunch_collection.url }}{% elsif catalog_collection != blank %}{{ catalog_collection.url }}{% else %}{{ routes.collections_url }}{% endif %}"
            class="marketplace-hero__button marketplace-hero__button--primary"
          >
            Shop lunch boxes
          </a>
          <a
            href="{% if catalog_collection != blank %}{{ catalog_collection.url }}{% else %}{{ routes.collections_url }}{% endif %}"
            class="marketplace-hero__button marketplace-hero__button--secondary"
          >
            Shop all products
          </a>
        </div>

        <div class="marketplace-hero__proof">
          <span class="marketplace-hero__proof-item">
            {% if all_reviews_count > 0 %}{{ all_reviews_count }}+ verified reviews{% else %}650+ verified reviews{% endif %}
          </span>
          <span class="marketplace-hero__proof-item">Original product photos</span>
          <span class="marketplace-hero__proof-item">Bulk gifting support</span>
        </div>

        <div class="marketplace-hero__quick-links">
          {%- if lunch_collection != blank -%}
            <a href="{{ lunch_collection.url }}" class="marketplace-hero__quick-link">Lunch Boxes</a>
          {%- endif -%}
          {%- if bottle_collection != blank -%}
            <a href="{{ bottle_collection.url }}" class="marketplace-hero__quick-link">Bottles &amp; Thermos</a>
          {%- endif -%}
          {%- if kids_collection != blank -%}
            <a href="{{ kids_collection.url }}" class="marketplace-hero__quick-link">Kids Themes</a>
          {%- endif -%}
          {%- if gifting_collection != blank -%}
            <a href="{{ gifting_collection.url }}" class="marketplace-hero__quick-link">Bulk Gifting</a>
          {%- endif -%}
        </div>
      </div>

      <div class="marketplace-hero__visual">
        <a
          href="{% if main_collection != blank %}{{ main_collection.url }}{% else %}{{ routes.collections_url }}{% endif %}"
          class="marketplace-hero__feature marketplace-hero__feature--main"
        >
          <div class="marketplace-hero__feature-copy">
            <span class="marketplace-hero__feature-label">
              {% if main_collection != blank %}Bestselling lunch boxes{% else %}Lunch-box range{% endif %}
            </span>
            <strong class="marketplace-hero__feature-title">
              {% if main_product != blank %}
                {{ main_product.title | escape }}
              {% else %}
                Lunch-box picks made for school routines.
              {% endif %}
            </strong>
            <div class="marketplace-hero__feature-meta">
              <span class="marketplace-hero__feature-pill">School-ready picks</span>
            </div>
          </div>
          <div class="marketplace-hero__feature-image-wrap">
            {%- if main_product != blank and main_product.featured_media != blank -%}
              {{
                main_product.featured_media
                | image_url: width: 1000
                | image_tag:
                  class: 'marketplace-hero__feature-image',
                  widths: '420, 640, 840, 1000',
                  loading: 'eager',
                  alt: main_product.title
              }}
            {%- elsif main_collection != blank and main_collection.image != blank -%}
              {{
                main_collection.image
                | image_url: width: 1000
                | image_tag:
                  class: 'marketplace-hero__feature-image',
                  widths: '420, 640, 840, 1000',
                  loading: 'eager',
                  alt: main_collection.title
              }}
            {%- endif -%}
          </div>
        </a>

        <a
          href="{% if kids_collection != blank %}{{ kids_collection.url }}{% else %}{{ routes.collections_url }}{% endif %}"
          class="marketplace-hero__feature"
        >
          <div class="marketplace-hero__feature-copy">
            <span class="marketplace-hero__feature-label">Theme favourites</span>
            <strong class="marketplace-hero__feature-title">
              {% if kids_product != blank %}{{ kids_product.title | escape }}{% else %}Character-led picks for gift-ready lunches.{% endif %}
            </strong>
            <div class="marketplace-hero__feature-meta">
              <span class="marketplace-hero__feature-pill">Character picks</span>
            </div>
          </div>
          <div class="marketplace-hero__feature-image-wrap">
            {%- if kids_product != blank and kids_product.featured_media != blank -%}
              {{
                kids_product.featured_media
                | image_url: width: 900
                | image_tag:
                  class: 'marketplace-hero__feature-image',
                  widths: '320, 520, 700, 900',
                  loading: 'lazy',
                  alt: kids_product.title
              }}
            {%- endif -%}
          </div>
        </a>

        <a
          href="{% if bottle_collection != blank %}{{ bottle_collection.url }}{% else %}{{ routes.collections_url }}{% endif %}"
          class="marketplace-hero__feature"
        >
          <div class="marketplace-hero__feature-copy">
            <span class="marketplace-hero__feature-label">Insulated carry</span>
            <strong class="marketplace-hero__feature-title">
              {% if bottle_product != blank %}
                {{ bottle_product.title | escape }}
              {% else %}
                Bottles and thermos for school and travel.
              {% endif %}
            </strong>
            <div class="marketplace-hero__feature-meta">
              <span class="marketplace-hero__feature-pill">Daily carry</span>
            </div>
          </div>
          <div class="marketplace-hero__feature-image-wrap">
            {%- if bottle_product != blank and bottle_product.featured_media != blank -%}
              {{
                bottle_product.featured_media
                | image_url: width: 900
                | image_tag:
                  class: 'marketplace-hero__feature-image',
                  widths: '320, 520, 700, 900',
                  loading: 'lazy',
                  alt: bottle_product.title
              }}
            {%- endif -%}
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "default": true,
      "label": "Animate feature cards"
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "default": 5,
      "label": "Animation speed"
    }
  ]
}
{% endschema %}
