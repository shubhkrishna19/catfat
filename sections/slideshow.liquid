<style>
.slideshow {
  position: relative;
  height: 500px;
  background: linear-gradient(135deg, #ff6b9d 0%, #e84a7f 50%, #ff8e53 100%);
  overflow: hidden;
}

@media (max-width: 768px) {
  .slideshow {
    height: 350px;
  }
}

.slideshow__slide {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.slideshow__slide.active {
  opacity: 1;
}

.slideshow__content {
  text-align: center;
  color: #fff;
  padding: 20px;
  max-width: 600px;
}

.slideshow__subtitle {
  font-size: 1rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 3px;
  margin-bottom: 10px;
  background: rgba(255,255,255,0.2);
  display: inline-block;
  padding: 8px 20px;
  border-radius: 25px;
}

.slideshow__title {
  font-size: 3rem;
  font-weight: 800;
  margin: 15px 0;
  text-shadow: 2px 2px 10px rgba(0,0,0,0.2);
}

@media (max-width: 768px) {
  .slideshow__title {
    font-size: 1.8rem;
  }
}

.slideshow__text {
  font-size: 1.1rem;
  margin-bottom: 25px;
  opacity: 0.95;
}

.slideshow__btn {
  display: inline-block;
  background: #fff;
  color: #ff6b9d;
  padding: 14px 35px;
  font-weight: 700;
  text-decoration: none;
  border-radius: 30px;
  transition: all 0.3s ease;
}

.slideshow__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

.slideshow__nav {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
}

.slideshow__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  cursor: pointer;
  transition: all 0.3s ease;
}

.slideshow__dot.active {
  background: #fff;
  transform: scale(1.3);
}

.slideshow__arrows {
  position: absolute;
  top: 50%;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 20px;
  box-sizing: border-box;
  transform: translateY(-50%);
  pointer-events: none;
}

.slideshow__arrow {
  width: 45px;
  height: 45px;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  pointer-events: auto;
  transition: all 0.3s ease;
}

.slideshow__arrow:hover {
  background: #fff;
  transform: scale(1.1);
}

.slideshow__arrow svg {
  width: 20px;
  height: 20px;
  fill: #333;
}
</style>

<div class="slideshow">
  <div class="slideshow__slide active">
    <div class="slideshow__content">
      <span class="slideshow__subtitle">New Collection</span>
      <h2 class="slideshow__title">Premium Lunch Boxes</h2>
      <p class="slideshow__text">Safe, stylish & perfect for your kids</p>
      <a href="{{ routes.collections_url }}/lunch-boxes" class="slideshow__btn">Shop Now</a>
    </div>
  </div>
  
  <div class="slideshow__slide">
    <div class="slideshow__content">
      <span class="slideshow__subtitle">Free Shipping</span>
      <h2 class="slideshow__title">On Orders ₹499+</h2>
      <p class="slideshow__text">Flat 50% Off on First Order</p>
      <a href="{{ routes.collections_url }}/sale" class="slideshow__btn">Grab Offer</a>
    </div>
  </div>
  
  <div class="slideshow__slide">
    <div class="slideshow__content">
      <span class="slideshow__subtitle">Water Bottles</span>
      <h2 class="slideshow__title">Stay Hydrated</h2>
      <p class="slideshow__text">Insulated bottles for school & office</p>
      <a href="{{ routes.collections_url }}/bottles" class="slideshow__btn">Shop Bottles</a>
    </div>
  </div>
  
  <div class="slideshow__arrows">
    <div class="slideshow__arrow" onclick="changeSlide(-1)">
      <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
    </div>
    <div class="slideshow__arrow" onclick="changeSlide(1)">
      <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
    </div>
  </div>
  
  <div class="slideshow__nav">
    <div class="slideshow__dot active" onclick="goToSlide(0)"></div>
    <div class="slideshow__dot" onclick="goToSlide(1)"></div>
    <div class="slideshow__dot" onclick="goToSlide(2)"></div>
  </div>
</div>

<script>
let currentSlide = 0;
const slides = document.querySelectorAll('.slideshow__slide');
const dots = document.querySelectorAll('.slideshow__dot');
const totalSlides = slides.length;

function showSlide(index) {
  slides.forEach(s => s.classList.remove('active'));
  dots.forEach(d => d.classList.remove('active'));
  
  slides[index].classList.add('active');
  dots[index].classList.add('active');
}

function changeSlide(direction) {
  currentSlide += direction;
  if (currentSlide >= totalSlides) currentSlide = 0;
  if (currentSlide < 0) currentSlide = totalSlides - 1;
  showSlide(currentSlide);
}

function goToSlide(index) {
  currentSlide = index;
  showSlide(currentSlide);
}

// Auto-rotate
let slideInterval = setInterval(() => changeSlide(1), 5000);

// Pause on hover
const slideshowEl = document.querySelector('.slideshow');
if (slideshowEl) {
  slideshowEl.addEventListener('mouseenter', () => {
    clearInterval(slideInterval);
  });
  
  slideshowEl.addEventListener('mouseleave', () => {
    slideInterval = setInterval(() => changeSlide(1), 5000);
  });
}
</script>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "default": true,
      "label": "Auto rotate"
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "default": 5,
      "label": "Change slides speed"
    }
  ]
}
{% endschema %}
