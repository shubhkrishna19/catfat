{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

<style>
  .collection-template {
    padding: 32px 0 56px;
  }

  .collection-template__hero {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    margin-bottom: 32px;
    background: linear-gradient(135deg, #fff5f8, #fff7ef);
  }

  .collection-template__hero-image {
    display: block;
    width: 100%;
    height: clamp(240px, 36vw, 420px);
    object-fit: cover;
  }

  .collection-template__hero-copy {
    position: absolute;
    inset: auto 0 0;
    padding: 28px;
    color: #fff;
    background: linear-gradient(180deg, rgba(30, 16, 28, 0) 0%, rgba(30, 16, 28, 0.78) 100%);
  }

  .collection-template__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .collection-template__title {
    margin: 16px 0 10px;
    font-size: clamp(32px, 5vw, 56px);
    line-height: 0.96;
    color: #2c1830;
  }

  .collection-template__hero-copy .collection-template__title {
    color: #fff;
  }

  .collection-template__description {
    max-width: 720px;
    font-size: 16px;
    line-height: 1.65;
    color: #6f5c68;
  }

  .collection-template__hero-copy .collection-template__description {
    color: rgba(255, 255, 255, 0.92);
  }

  .collection-template__summary {
    display: grid;
    gap: 20px;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    margin-bottom: 28px;
  }

  .collection-template__toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border: 1px solid rgba(232, 74, 127, 0.12);
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff 0%, #fff8fb 100%);
    box-shadow: 0 12px 30px rgba(232, 74, 127, 0.08);
    margin-bottom: 24px;
  }

  .collection-template__count {
    font-size: 15px;
    color: #5f4d59;
  }

  .collection-template__count strong {
    color: #e84a7f;
  }

  .collection-template__sort {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #5f4d59;
    font-size: 14px;
    font-weight: 600;
  }

  .collection-template__sort select {
    min-width: 220px;
    padding: 12px 40px 12px 16px;
    border: 1px solid rgba(232, 74, 127, 0.18);
    border-radius: 999px;
    background: #fff;
    color: #2c1830;
    font: inherit;
  }

  .collection-template__grid {
    display: grid;
    grid-template-columns: repeat(var(--collection-grid-columns), minmax(0, 1fr));
    gap: 20px;
  }

  .collection-template__item {
    display: flex;
    min-width: 0;
    height: 100%;
  }

  .collection-template__item .market-card {
    width: 100%;
  }

  .collection-template__pagination {
    margin-top: 32px;
  }

  .collection-template__pagination .pagination {
    justify-content: center;
  }

  .collection-template__empty {
    padding: 48px 24px;
    text-align: center;
    border-radius: 24px;
    background: linear-gradient(180deg, #fff8fb 0%, #fff 100%);
    border: 1px solid rgba(232, 74, 127, 0.12);
  }

  .collection-template__empty h2 {
    margin: 0 0 12px;
    color: #2c1830;
    font-size: 28px;
  }

  .collection-template__empty p {
    margin: 0;
    color: #6f5c68;
  }

  @media screen and (max-width: 989px) {
    .collection-template__summary {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .collection-template__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .collection-template {
      padding: 24px 0 44px;
    }

    .collection-template__hero {
      border-radius: 22px;
    }

    .collection-template__hero-copy {
      padding: 20px;
    }

    .collection-template__toolbar {
      padding: 16px;
    }

    .collection-template__sort {
      width: 100%;
      justify-content: space-between;
    }

    .collection-template__sort select {
      min-width: 0;
      width: 100%;
    }
  }

  @media screen and (max-width: 579px) {
    .collection-template__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{%- liquid
  assign current_sort = collection.sort_by | default: collection.default_sort_by
  assign products_per_page = section.settings.products_per_page
-%}

<section
  class="collection-template page-width"
  style="--collection-grid-columns: {{ section.settings.columns_desktop }};"
>
  {%- if section.settings.show_collection_image and collection.image != blank -%}
    <div class="collection-template__hero">
      {{
        collection.image
        | image_url: width: 1800
        | image_tag:
          class: 'collection-template__hero-image',
          widths: '750, 1100, 1500, 1800',
          loading: 'eager',
          alt: collection.title
      }}
      <div class="collection-template__hero-copy">
        <span class="collection-template__eyebrow">CatFat Collection</span>
        <h1 class="collection-template__title">{{ collection.title | escape }}</h1>
        {%- if section.settings.show_collection_description and collection.description != blank -%}
          <div class="collection-template__description rte">
            {{ collection.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <div class="collection-template__summary">
      <div>
        <span class="collection-template__eyebrow">CatFat Collection</span>
        <h1 class="collection-template__title">{{ collection.title | escape }}</h1>
        {%- if section.settings.show_collection_description and collection.description != blank -%}
          <div class="collection-template__description rte">
            {{ collection.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- paginate collection.products by products_per_page -%}
    <div class="collection-template__toolbar">
      <p class="collection-template__count">
        <strong>{{ collection.products_count }}</strong>
        products for
        <strong>{{ collection.title | escape }}</strong>
      </p>

      <form class="collection-template__sort" method="get" action="{{ collection.url }}">
        <label for="CollectionSort-{{ section.id }}">Sort by</label>
        <select
          id="CollectionSort-{{ section.id }}"
          name="sort_by"
          onchange="this.form.submit()"
        >
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if option.value == current_sort %}selected{% endif %}>
              {{ option.name }}
            </option>
          {%- endfor -%}
        </select>
      </form>
    </div>

    {%- if collection.products_count > 0 -%}
      <div class="collection-template__grid">
        {%- for product in collection.products -%}
          <div class="collection-template__item">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="collection-template__pagination">
          {% render 'pagination', paginate: paginate %}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="collection-template__empty">
        <h2>No products found</h2>
        <p>We will refill this collection with fresh favorites soon.</p>
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": true,
      "label": "Show collection image"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "Show collection description"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Desktop columns"
    }
  ]
}
{% endschema %}
