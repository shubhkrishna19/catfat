{{ 'template-collection.css' | asset_url | stylesheet_tag }}

<style>
.collection-page {
  padding: 40px 0;
  background: #fff;
}

.collection-header {
  text-align: center;
  margin-bottom: 40px;
}

.collection-title {
  font-size: 2.5rem;
  font-weight: 800;
  color: #e84a7f;
  margin-bottom: 15px;
}

.collection-title::after {
  content: '';
  display: block;
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #ff6b9d, #e84a7f);
  margin: 15px auto 0;
  border-radius: 2px;
}

.collection-description {
  font-size: 1.1rem;
  color: #666;
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.6;
}

/* Collection Filters */
.collection-filters {
  margin-bottom: 30px;
  padding: 20px;
  background: #f9f9f9;
  border-radius: 12px;
}

.filter-heading {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 15px;
  color: #333;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.filter-btn {
  padding: 8px 16px;
  border: 2px solid #e0e0e0;
  background: white;
  border-radius: 25px;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.3s ease;
  text-decoration: none;
  color: #333;
}

.filter-btn:hover {
  border-color: #ff6b9d;
  color: #ff6b9d;
}

.filter-btn.active {
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  border-color: #ff6b9d;
  color: white;
}

.collection-grid {
  margin-top: 20px;
}

.collection__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}

@media (max-width: 1024px) {
  .collection__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .collection__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  .collection-title {
    font-size: 1.8rem;
  }
  
  .filter-options {
    justify-content: center;
  }
}

.collection-empty {
  text-align: center;
  padding: 80px 20px;
  background: #f9f9f9;
  border-radius: 12px;
}

.collection-empty h2 {
  font-size: 1.5rem;
  color: #333;
  margin-bottom: 10px;
}

.collection-empty p {
  color: #666;
  font-size: 1.1rem;
}
</style>

<div class="collection-page page-width">
  <div class="collection-header">
    <h1 class="collection-title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-description">{{ collection.description }}</div>
    {%- endif -%}
  </div>

  {%- if collection.products.size > 0 -%}
    <!-- Category Filter -->
    {% assign all_products = collection.products %}
    {% assign categories = "" %}
    {% for product in all_products %}
      {% if product.type != blank and product.type != "" %}
        {% assign categories = categories | append: product.type | append: "," %}
      {% endif %}
    {% endfor %}
    {% assign unique_categories = categories | split: "," | compact | uniq %}
    
    {% if unique_categories.size > 0 %}
    <div class="collection-filters">
      <div class="filter-heading">Filter by Category:</div>
      <div class="filter-options">
        <button class="filter-btn active" data-filter="all">All</button>
        {% for cat in unique_categories %}
          <button class="filter-btn" data-filter="{{ cat | handle }}">{{ cat }}</button>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <div class="collection-grid">
      <ul class="collection__grid" role="list" id="product-grid">
        {%- for product in collection.products -%}
          <li class="grid__item" data-category="{{ product.type | handle }}">
            {% render 'card-product', card_product: product %}
          </li>
        {%- endfor -%}
      </ul>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const filterBtns = document.querySelectorAll('.filter-btn');
        const products = document.querySelectorAll('#product-grid .grid__item');
        
        filterBtns.forEach(btn => {
          btn.addEventListener('click', function() {
            const filter = this.dataset.filter;
            
            // Update active button
            filterBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            // Filter products
            products.forEach(product => {
              if (filter === 'all' || product.dataset.category === filter) {
                product.style.display = '';
              } else {
                product.style.display = 'none';
              }
            });
          });
        });
      });
    </script>

  {%- else -%}
    <div class="collection-empty">
      <h2>No products found</h2>
      <p>We're sorry, there are no products in this collection yet.</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": true,
      "label": "Show collection image"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "Show collection description"
    }
  ]
}
{% endschema %}
