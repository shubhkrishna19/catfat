{{ 'section-marketplace-marquee.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign badge_labels = '620+ Verified Reviews|BPA Free Materials|Microwave Safe|Leak-Proof Design|Easy to Clean|Ships Across India|COD Available|Kids-Favourite Themes|Personalised Options' | split: '|'
  assign badge_icons = 'reviews|materials|microwave|design|clean|shipping|cod|themes|personalise' | split: '|'
-%}

<section class="marketplace-marquee" data-rail-couple>
  <div class="marketplace-marquee__shell">
    <div class="marketplace-marquee__track" aria-label="Catfat highlights">
      {%- for duplicate in (1..2) -%}
        <div class="marketplace-marquee__group" aria-hidden="{% if duplicate == 2 %}true{% else %}false{% endif %}">
          {%- for label in badge_labels -%}
            {%- assign icon = badge_icons[forloop.index0] -%}
            {% render 'trust-badge', label: label, icon: icon %}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marketplace Ticker",
  "settings": []
}
{% endschema %}
