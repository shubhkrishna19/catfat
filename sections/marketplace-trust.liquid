{{ 'section-marketplace-trust.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign all_reviews_count = shop.metafields.judgeme.all_reviews_count | default: '620' | plus: 0
-%}

<section class="marketplace-trust">
  <div class="page-width">
    <div class="marketplace-trust__inner">
      <div class="marketplace-trust__header" data-scrub data-scrub-y="28" data-scrub-opacity-from="0">
        <h2 class="marketplace-trust__title">Built for everyday lunches. Trusted by real families.</h2>
      </div>

      <div class="marketplace-trust__grid">
        <article class="marketplace-trust__item" data-card-depth data-scrub-from="0.05">
          <span class="marketplace-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3.75l2.55 5.17 5.71.83-4.13 4.03.98 5.69L12 16.81 6.89 19.47l.98-5.69-4.13-4.03 5.71-.83L12 3.75z" />
            </svg>
          </span>
          <h3 class="marketplace-trust__item-title">Verified Reviews</h3>
          <p class="marketplace-trust__item-copy">{{ all_reviews_count }}+ real customer reviews from everyday users</p>
        </article>

        <article class="marketplace-trust__item" data-card-depth data-scrub-from="0.1">
          <span class="marketplace-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M4.75 7.25 12 3.75l7.25 3.5v9.5L12 20.25l-7.25-3.5v-9.5z" />
              <path d="M4.75 7.25 12 11l7.25-3.75" />
              <path d="M12 11v9.25" />
            </svg>
          </span>
          <h3 class="marketplace-trust__item-title">Real Product Experience</h3>
          <p class="marketplace-trust__item-copy">Original photos and honest feedback from customers</p>
        </article>

        <article class="marketplace-trust__item" data-card-depth data-scrub-from="0.15">
          <span class="marketplace-trust__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7.25 8.25H4.5V5.5" />
              <path d="M16.75 15.75h2.75v2.75" />
              <path d="M6.2 18.05A8 8 0 0 0 19.1 15.5" />
              <path d="M17.8 5.95A8 8 0 0 0 4.9 8.5" />
            </svg>
          </span>
          <h3 class="marketplace-trust__item-title">Easy &amp; Reliable</h3>
          <p class="marketplace-trust__item-copy">7-day returns and quick support you can trust</p>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marketplace Trust",
  "settings": []
}
{% endschema %}
