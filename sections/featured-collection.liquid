<style>
.featured-collection {
  padding: 40px 20px;
  max-width: 1400px;
  margin: 0 auto;
}

/* Banner Image */
.featured-collection__banner {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  margin-bottom: 40px;
}

.featured-collection__banner-image {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.featured-collection__banner-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 107, 157, 0.85), rgba(232, 74, 127, 0.7));
  display: flex;
  align-items: center;
  justify-content: center;
}

.featured-collection__banner-title {
  font-size: 2.5rem;
  font-weight: 800;
  color: #fff;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
  text-align: center;
}

.featured-collection__banner-subtitle {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.9);
  text-align: center;
  margin-top: 8px;
}

@media (max-width: 768px) {
  .featured-collection__banner-image {
    height: 150px;
  }
  .featured-collection__banner-title {
    font-size: 1.8rem;
  }
}

/* Header */
.featured-collection__header {
  text-align: center;
  margin-bottom: 30px;
}

.featured-collection__title {
  font-size: 2rem;
  font-weight: 800;
  color: #333;
  margin-bottom: 8px;
}

.featured-collection__desc {
  color: #666;
  font-size: 0.95rem;
}

/* Grid */
.featured-collection__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

@media (max-width: 1200px) {
  .featured-collection__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .featured-collection__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
}

@media (max-width: 480px) {
  .featured-collection__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
}

/* Product Card - Playful Style */
.product-card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2px solid transparent;
}

.product-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 30px rgba(255, 107, 157, 0.2);
  border-color: #ff6b9d;
}

.product-card__image {
  position: relative;
  aspect-ratio: 1;
  background: linear-gradient(135deg, #fff5f8 0%, #ffeef3 100%);
  overflow: hidden;
}

.product-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.product-card:hover .product-card__image img {
  transform: scale(1.08);
}

/* Badge */
.product-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  color: #fff;
  padding: 6px 14px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  border-radius: 20px;
  box-shadow: 0 4px 10px rgba(255, 107, 157, 0.4);
  z-index: 2;
}

.product-card__badge.sale {
  background: linear-gradient(135deg, #ffd93d, #ffb300);
  box-shadow: 0 4px 10px rgba(255, 217, 61, 0.4);
}

/* Wishlist Heart */
.product-card__wishlist {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 36px;
  height: 36px;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  transition: all 0.3s ease;
  z-index: 2;
}

.product-card__wishlist:hover {
  transform: scale(1.1);
  background: #ff6b9d;
  color: #fff;
}

/* Quick View */
.product-card__quick-view {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 10px;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 2;
}

.product-card:hover .product-card__quick-view {
  transform: translateY(0);
}

.quick-view-btn {
  width: 100%;
  background: #fff;
  color: #333;
  padding: 10px;
  border: none;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.quick-view-btn:hover {
  background: #ff6b9d;
  color: #fff;
}

/* Content */
.product-card__content {
  padding: 14px;
}

.product-card__vendor {
  font-size: 0.7rem;
  color: #ff6b9d;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
  margin-bottom: 4px;
}

.product-card__title {
  font-size: 0.95rem;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
  text-decoration: none;
  display: block;
  line-height: 1.4;
  transition: color 0.2s ease;
}

.product-card__title:hover {
  color: #ff6b9d;
}

.product-card__price {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.product-card__price-current {
  font-size: 1.1rem;
  font-weight: 700;
  color: #ff6b9d;
}

.product-card__price-compare {
  font-size: 0.85rem;
  color: #999;
  text-decoration: line-through;
}

.product-card__price-sale {
  color: #e84a7f;
}

/* Add to Cart Button */
.product-card__btn {
  width: 100%;
  padding: 12px;
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-weight: 600;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.3s ease;
}

.product-card__btn:hover {
  transform: scale(1.02);
  box-shadow: 0 6px 20px rgba(255, 107, 157, 0.4);
}

.product-card__btn:active {
  transform: scale(0.98);
}
</style>

<div class="featured-collection">
  {%- if section.settings.banner_image != blank -%}
    <div class="featured-collection__banner">
      <img src="{{ section.settings.banner_image | image_url: width: 1400 }}" 
           alt="{{ section.settings.title }}"
           class="featured-collection__banner-image"
           loading="lazy">
      <div class="featured-collection__banner-overlay">
        <div>
          <h2 class="featured-collection__banner-title">{{ section.settings.title }}</h2>
          {%- if section.settings.banner_subtitle != blank -%}
            <p class="featured-collection__banner-subtitle">{{ section.settings.banner_subtitle }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- else -%}
    <div class="featured-collection__header">
      <h2 class="featured-collection__title">{{ section.settings.title | default: 'Featured Products' }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="featured-collection__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}
  
  <div class="featured-collection__grid">
    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection and collection.products.size > 0 -%}
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        <div class="product-card">
          <a href="{{ product.url }}" class="product-card__image">
            {%- if product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}" 
                   alt="{{ product.title | escape }}"
                   loading="lazy">
            {%- else -%}
              <img src="https://placehold.co/400x400/ff6b9d/ffffff?text={{ product.title | url_encode }}" 
                   alt="{{ product.title | escape }}">
            {%- endif -%}
            
            {%- if product.tags contains 'new' -%}
              <span class="product-card__badge">New</span>
            {%- elsif product.compare_at_price > product.price -%}
              <span class="product-card__badge sale">Sale</span>
            {%- endif -%}
            
            <div class="product-card__wishlist" onclick="event.preventDefault(); event.stopPropagation(); alert('Wishlist coming soon!')">
              ♥
            </div>
            
            <div class="product-card__quick-view">
              <button class="quick-view-btn">Quick View</button>
            </div>
          </a>
          
          <div class="product-card__content">
            {%- if product.vendor != blank -%}
              <div class="product-card__vendor">{{ product.vendor }}</div>
            {%- endif -%}
            
            <a href="{{ product.url }}" class="product-card__title">{{ product.title }}</a>
            
            <div class="product-card__price">
              <span class="product-card__price-current">
                {%- if product.price_varies -%}
                  From {{ product.price_min | money }}
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </span>
              {%- if product.compare_at_price > product.price -%}
                <span class="product-card__price-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
            
            <button class="product-card__btn" onclick="addToCart({{ product.selected_or_first_available_variant.id }})">
              Add to Cart
            </button>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <p style="grid-column: 1/-1; text-align: center; color: #666;">No products found in this collection.</p>
    {%- endif -%}
  </div>
</div>

<script>
function addToCart(variantId) {
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ 
      items: [{ id: variantId, quantity: 1 }]
    })
  })
  .then(response => response.json())
  .then(data => {
    window.location.href = '/cart';
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Failed to add to cart. Please try again.');
  });
}
</script>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Featured Products",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner Subtitle"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 12,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
