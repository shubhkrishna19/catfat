{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'section-market-shelf.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = section.settings.collection
  if collection != blank and collection.url == blank
    assign collection = collections[section.settings.collection]
  endif

  assign shelf_title = section.settings.title
  if shelf_title == blank and collection != blank
    assign shelf_title = collection.title
  endif

  assign shelf_title_downcase = shelf_title | downcase
  assign shelf_eyebrow = 'Shop by category'
  assign shelf_description = section.settings.description

  if shelf_title_downcase contains 'best sellers'
    assign shelf_eyebrow = 'Best sellers'
  endif

  if collection != blank
    case collection.handle
      when 'lunch-box'
        unless shelf_title_downcase contains 'best sellers'
          assign shelf_eyebrow = 'Lunch boxes'
        endunless
        if shelf_description == blank
          assign shelf_description = 'School-ready lunch boxes with clear pricing and simpler comparison.'
        endif
      when 'bottles-flasks'
        assign shelf_eyebrow = 'Bottles & thermos'
        if shelf_description == blank
          assign shelf_description = 'Insulated hydration picks with cleaner browsing and clearer value.'
        endif
      when 'kids-collections'
        assign shelf_eyebrow = 'Kids themes'
        if shelf_description == blank
          assign shelf_description = 'Theme-led favourites for gifting and everyday school use.'
        endif
      when 'india-s-biggest-lunch-sale-upto-80'
        assign shelf_eyebrow = 'Sale picks'
        if shelf_description == blank
          assign shelf_description = 'Sale-first picks where the savings are visible at a glance.'
        endif
      when 'new-arrivals'
        assign shelf_eyebrow = 'New arrivals'
        if shelf_description == blank
          assign shelf_description = 'Recent additions presented in a cleaner, easier-to-scan shelf.'
        endif
    endcase
  endif

  if shelf_description == blank
    assign shelf_description = 'A cleaner product shelf built around real Catfat catalog data.'
  endif

  assign products_limit = section.settings.products_to_show
  if products_limit == blank
    assign products_limit = 8
  endif
-%}

<section class="market-shelf page-width">
  <div class="market-shelf__header">
    <div>
      <span class="market-shelf__eyebrow">{{ shelf_eyebrow }}</span>
      <h2 class="market-shelf__title">{{ shelf_title | escape }}</h2>
      <p class="market-shelf__description">{{ shelf_description }}</p>
    </div>

    {%- if collection != blank and collection.url != blank -%}
      <a href="{{ collection.url }}" class="market-shelf__link">View all</a>
    {%- endif -%}
  </div>

  {%- assign shown_count = 0 -%}

  {%- if collection != blank and collection.products.size > 0 -%}
    <div class="market-shelf__grid">
      {%- for product in collection.products -%}
        {%- if product.available -%}
          <div class="market-shelf__item">
            {% render 'product-card', product: product %}
          </div>
          {%- assign shown_count = shown_count | plus: 1 -%}
          {%- if shown_count >= products_limit -%}
            {%- break -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if shown_count < products_limit -%}
        {%- for product in collection.products -%}
          {%- unless product.available -%}
            <div class="market-shelf__item">
              {% render 'product-card', product: product %}
            </div>
            {%- assign shown_count = shown_count | plus: 1 -%}
            {%- if shown_count >= products_limit -%}
              {%- break -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="market-shelf__empty">
      This shelf is waiting for products from the selected Catfat collection.
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Featured Products",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 12,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
