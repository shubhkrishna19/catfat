<style>
.shop-by-age {
  padding: 60px 0;
  background: #fff;
}

.shop-by-age .section-header {
  text-align: center;
  margin-bottom: 40px;
}

.shop-by-age .section-title {
  font-size: 2.5rem;
  font-weight: 800;
  color: #e84a7f;
  margin: 0;
  position: relative;
  display: inline-block;
}

.shop-by-age .section-title::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, #ff6b9d, #e84a7f);
  border-radius: 2px;
}

.shop-by-age .age-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}

@media (max-width: 1024px) {
  .shop-by-age .age-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .shop-by-age .age-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }
  .shop-by-age .section-title {
    font-size: 1.8rem;
  }
}

.shop-by-age .age-card {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  aspect-ratio: 1;
  background: #f5f5f5;
  transition: transform 0.3s, box-shadow 0.3s;
  cursor: pointer;
}

.shop-by-age .age-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
}

.shop-by-age .age-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s;
}

.shop-by-age .age-card:hover img {
  transform: scale(1.1);
}

.shop-by-age .age-card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20px;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  text-align: center;
}

.shop-by-age .age-card-title {
  color: #fff;
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.shop-by-age .age-card-range {
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.85rem;
  margin-top: 5px;
}

.shop-by-age .age-card a {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
}

.shop-by-age .age-card-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  background: linear-gradient(135deg, #ff6b9d20, #e84a7f20);
}

.shop-by-age .age-card-placeholder svg {
  width: 60px;
  height: 60px;
  color: #e84a7f;
  opacity: 0.5;
}

.shop-by-age .age-card-placeholder span {
  margin-top: 10px;
  color: #e84a7f;
  font-weight: 600;
}
</style>

<div class="shop-by-age section">
  <div class="page-width">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="age-grid">
      {%- for i in (1..8) -%}
        {%- assign age_image = 'age_image_' | append: i -%}
        {%- assign age_title = 'age_title_' | append: i -%}
        {%- assign age_range = 'age_range_' | append: i -%}
        {%- assign age_link = 'age_link_' | append: i -%}
        
        <div class="age-card">
          {%- if section.settings[age_image] != blank -%}
            <img src="{{ section.settings[age_image] | img_url: '400x400' }}" 
                 alt="{{ section.settings[age_title] }}"
                 loading="lazy">
          {%- else -%}
            <div class="age-card-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              <span>{{ section.settings[age_title] }}</span>
            </div>
          {%- endif -%}
          
          <div class="age-card-overlay">
            <h3 class="age-card-title">{{ section.settings[age_title] }}</h3>
            <p class="age-card-range">{{ section.settings[age_range] }}</p>
          </div>
          
          {%- if section.settings[age_link] != blank -%}
            <a href="{{ section.settings[age_link] }}" aria-label="{{ section.settings[age_title] }}"></a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

