{{ 'customer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'customer.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="customer-auth section-{{ section.id }}-padding">
  <div class="customer-auth__frame">
    <div class="customer-auth__card">
      <div class="customer-auth__brand">
        <span class="customer-auth__eyebrow">Reset password</span>
        <h1 class="customer-auth__title">Choose a fresh password and get back to your Catfat account.</h1>
        <p class="customer-auth__copy">A new password will reopen your order history, addresses, and support tools instantly.</p>
      </div>

      {%- form 'reset_customer_password', class: 'customer-form js-customer-validate', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <ul class="customer-form__error-list" role="alert">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="customer-form__group">
          <label class="customer-form__label" for="ResetPassword">New password</label>
          <div class="customer-form__control">
            <input class="customer-form__input customer-form__password js-validate-input" type="password" name="customer[password]" id="ResetPassword" autocomplete="new-password" minlength="5" placeholder="Create a new password" required>
            <button type="button" class="customer-password-toggle" aria-controls="ResetPassword" data-password-toggle>Show</button>
          </div>
          <p class="customer-field-error js-field-error"></p>
        </div>

        <div class="customer-form__group">
          <label class="customer-form__label" for="ResetPasswordConfirm">Confirm password</label>
          <div class="customer-form__control">
            <input class="customer-form__input customer-form__password js-validate-input" type="password" name="customer[password_confirmation]" id="ResetPasswordConfirm" autocomplete="new-password" minlength="5" placeholder="Confirm the new password" data-match-field="ResetPassword" required>
            <button type="button" class="customer-password-toggle" aria-controls="ResetPasswordConfirm" data-password-toggle>Show</button>
          </div>
          <p class="customer-field-error js-field-error"></p>
        </div>

        <button class="customer-button" type="submit">Save new password</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "settings": [
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ]
}
{% endschema %}
