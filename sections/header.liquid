{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-search.css' | asset_url | stylesheet_tag }}
{{ 'component-menu-drawer.css' | asset_url | stylesheet_tag }}

<style>
:root {
  --header-bg: #ff6b9d;
  --header-text: #ffffff;
}

.header {
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  padding: 12px 20px;
  display: flex !important;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 100;
}

.header__left {
  display: flex;
  align-items: center;
  gap: 15px;
}

.header__menu-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
}

.header__menu-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: #fff;
  margin: 5px 0;
  border-radius: 2px;
}

.header__logo {
  font-size: 1.4rem;
  font-weight: 800;
  color: #fff !important;
  text-decoration: none;
  letter-spacing: -0.5px;
}

.header__nav {
  display: flex;
  gap: 25px;
}

.header__nav-link {
  color: #fff !important;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 5px 0;
  position: relative;
}

.header__nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background: #fff;
  transition: width 0.3s ease;
}

.header__nav-link:hover::after {
  width: 100%;
}

.header__right {
  display: flex;
  align-items: center;
  gap: 15px;
}

.header__icon-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header__icon-btn svg {
  width: 22px;
  height: 22px;
  fill: #fff;
}

.header__cart-count {
  background: #fff;
  color: #ff6b9d;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 10px;
  margin-left: -5px;
  margin-top: -10px;
}

/* Mobile Styles */
@media (max-width: 768px) {
  .header__nav {
    display: none;
  }
  
  .header__menu-toggle {
    display: block;
  }
  
  .header {
    padding: 10px 15px;
  }
  
  .header__logo {
    font-size: 1.2rem;
  }
}

/* Mobile Menu Drawer */
.mobile-menu-drawer {
  position: fixed;
  top: 0;
  left: -100%;
  width: 280px;
  height: 100vh;
  background: #fff;
  z-index: 1000;
  transition: left 0.3s ease;
  overflow-y: auto;
  box-shadow: 2px 0 10px rgba(0,0,0,0.1);
}

.mobile-menu-drawer.open {
  left: 0;
}

.mobile-menu-drawer__header {
  background: linear-gradient(135deg, #ff6b9d, #e84a7f);
  padding: 15px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mobile-menu-drawer__close {
  background: none;
  border: none;
  color: #fff;
  font-size: 1.5rem;
  cursor: pointer;
}

.mobile-menu-drawer__links {
  padding: 20px 15px;
}

.mobile-menu-drawer__link {
  display: block;
  color: #333;
  text-decoration: none;
  padding: 12px 0;
  font-weight: 600;
  border-bottom: 1px solid #eee;
}

.mobile-menu-drawer__overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.mobile-menu-drawer__overlay.open {
  opacity: 1;
  visibility: visible;
}
</style>

<div class="header">
  <div class="header__left">
    <button class="header__menu-toggle" onclick="toggleMobileMenu()">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <a href="{{ routes.root_url }}" class="header__logo">
      {{ section.settings.logo_text | default: 'CatFat' }}
    </a>
  </div>
  
  <nav class="header__nav">
    <a href="{{ routes.root_url }}" class="header__nav-link">Home</a>
    <a href="{{ routes.collections_url }}" class="header__nav-link">Shop</a>
    <a href="{{ routes.collections_url }}/new-arrivals" class="header__nav-link">New</a>
    <a href="{{ routes.pages_url }}/about" class="header__nav-link">About</a>
    <a href="{{ routes.contact_url }}" class="header__nav-link">Contact</a>
  </nav>
  
  <div class="header__right">
    <a href="{{ routes.search_url }}" class="header__icon-btn" aria-label="Search">
      <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
    </a>
    <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">
      <svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
    </a>
    <a href="{{ routes.cart_url }}" class="header__icon-btn" aria-label="Cart">
      <svg viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
      {% if cart.item_count > 0 %}
        <span class="header__cart-count">{{ cart.item_count }}</span>
      {% endif %}
    </a>
  </div>
</div>

<!-- Mobile Menu -->
<div class="mobile-menu-drawer__overlay" onclick="toggleMobileMenu()"></div>
<div class="mobile-menu-drawer">
  <div class="mobile-menu-drawer__header">
    <span style="color: #fff; font-weight: 700;">Menu</span>
    <button class="mobile-menu-drawer__close" onclick="toggleMobileMenu()">×</button>
  </div>
  <div class="mobile-menu-drawer__links">
    <a href="{{ routes.root_url }}" class="mobile-menu-drawer__link">Home</a>
    <a href="{{ routes.collections_url }}" class="mobile-menu-drawer__link">All Products</a>
    <a href="{{ routes.collections_url }}/new-arrivals" class="mobile-menu-drawer__link">New Arrivals</a>
    <a href="{{ routes.collections_url }}/best-sellers" class="mobile-menu-drawer__link">Best Sellers</a>
    <a href="{{ routes.pages_url }}/about" class="mobile-menu-drawer__link">About Us</a>
    <a href="{{ routes.pages_url }}/contact" class="mobile-menu-drawer__link">Contact</a>
    <a href="{{ routes.account_url }}" class="mobile-menu-drawer__link">My Account</a>
  </div>
</div>

<script>
function toggleMobileMenu() {
  document.querySelector('.mobile-menu-drawer').classList.toggle('open');
  document.querySelector('.mobile-menu-drawer__overlay').classList.toggle('open');
}
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "default": "CatFat",
      "label": "Logo Text"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 200,
      "step": 10,
      "default": 120,
      "label": "Logo Width"
    }
  ]
}
{% endschema %}
