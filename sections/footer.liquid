{%- liquid
  assign shop_all_url = routes.all_products_collection_url
  assign lunch_collection = collections['lunch-box']
  assign bottles_collection = collections['bottles-flasks']
  assign kids_collection = collections['kids-collections']
  assign sale_collection = collections['india-s-biggest-lunch-sale-upto-80']
  assign gifting_collection = collections['corporate-gifting-bulk-gifting']

  assign lunch_url = lunch_collection.url | default: routes.collections_url
  assign bottles_url = bottles_collection.url | default: routes.collections_url
  assign kids_url = kids_collection.url | default: routes.collections_url
  assign sale_url = sale_collection.url | default: routes.collections_url
  assign gifting_url = gifting_collection.url | default: routes.collections_url
-%}

<footer class="catfat-footer">
  <div class="page-width catfat-footer__inner">
    <span class="catfat-footer__topline">Smart lunchware for every Indian school day.</span>

    <div class="catfat-footer__grid">
      <div class="catfat-footer__brand">
        <h2 class="catfat-footer__brand-title">India's favourite lunch boxes & bottles for kids.</h2>
        <p class="catfat-footer__brand-text">
          BPA-free, microwave-safe, leak-proof lunchware designed for everyday Indian school life. Free delivery above ₹499. COD available.
        </p>

        <div class="catfat-footer__trust">
          <span class="catfat-footer__trust-pill">BPA Free</span>
          <span class="catfat-footer__trust-pill">Microwave Safe</span>
          <span class="catfat-footer__trust-pill">Leak Proof</span>
          <span class="catfat-footer__trust-pill">COD Available</span>
        </div>

        <div class="catfat-footer__contact-list">
          <a class="catfat-footer__contact-link" href="https://wa.me/918178136702">
            <span>WhatsApp</span> +91 81781 36702
          </a>
          <a class="catfat-footer__contact-link" href="mailto:support@catfatindia.com">
            <span>Email</span> support@catfatindia.com
          </a>
        </div>
      </div>

      <div>
        <h3 class="catfat-footer__heading">Shop</h3>
        <ul class="catfat-footer__links">
          <li><a href="{{ shop_all_url }}">All Products</a></li>
          <li><a href="{{ lunch_url }}">Lunch Boxes</a></li>
          <li><a href="{{ bottles_url }}">Bottles and Flasks</a></li>
          <li><a href="{{ kids_url }}">Kids Picks</a></li>
          <li><a href="{{ sale_url }}">Live Sale</a></li>
        </ul>
      </div>

      <div>
        <h3 class="catfat-footer__heading">Support</h3>
        <ul class="catfat-footer__links">
          <li><a href="/pages/contact-us">Contact Us</a></li>
          <li><a href="{{ gifting_url }}">Bulk Gifting</a></li>
          <li><a href="/pages/terms-and-conditions">Terms and Conditions</a></li>
          <li><a href="{{ routes.account_url }}">My Account</a></li>
        </ul>
      </div>

      <div class="catfat-footer__signup">
        <div class="catfat-footer__signup-card">
          <span class="catfat-footer__signup-eyebrow">Coupons inbox</span>
          <h3 class="catfat-footer__heading catfat-footer__signup-title">Get Coupons First</h3>
          <p class="catfat-footer__support-copy">
            Discount codes, latest product updates, and early access to launches — before they sell out.
          </p>

          {%- form 'customer', class: 'catfat-footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="catfat-footer__newsletter-fields">
              <input
                type="email"
                name="contact[email]"
                class="catfat-footer__newsletter-input"
                value="{{ form.email }}"
                placeholder="you@email.com"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required
              >
              <button type="submit" class="catfat-footer__newsletter-button">
                <span>Unlock 10% off</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7"/>
                </svg>
              </button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="catfat-footer__newsletter-message">
                You are in. Watch your inbox for coupons and new-drop updates.
              </p>
            {%- elsif form.errors -%}
              <ul class="catfat-footer__newsletter-errors" role="alert">
                {%- for field in form.errors -%}
                  <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          {%- endform -%}

          <ul class="catfat-footer__signup-perks">
            <li><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg> Welcome 10% off</li>
            <li><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg> Early-access drops</li>
            <li><svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg> No spam ever</li>
          </ul>
        </div>
      </div>
    </div>

