<script>
  (() => {
    const initFooterWhatsappCollisionGuard = () => {
      const footer = document.querySelector('.catfat-footer');
      const whatsappButton = document.querySelector('.custom_bottom_whatsapp_btn');

      if (!footer || !whatsappButton || !('IntersectionObserver' in window)) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            whatsappButton.classList.toggle('is-hidden-near-footer', entry.isIntersecting);
          });
        },
        {
          rootMargin: '0px 0px -40px 0px',
          threshold: 0.1
        }
      );

      observer.observe(footer);
    };

    document.addEventListener('DOMContentLoaded', initFooterWhatsappCollisionGuard);
    document.addEventListener('shopify:section:load', initFooterWhatsappCollisionGuard);
  })();
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_theme_toggle",
      "default": true,
      "label": "Show light/dark toggle"
    },
    {
      "type": "select",
      "id": "default_theme_mode",
      "label": "Default theme mode",
      "default": "light",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" },
        { "value": "system", "label": "Match device" }
      ]
    },
    {
      "type": "text",
      "id": "theme_toggle_heading",
      "default": "View mode",
      "label": "Toggle heading"
    },
    {
      "type": "textarea",
      "id": "theme_toggle_copy",
      "default": "Switch between light and dark storefront views while you review the build.",
      "label": "Toggle copy"
    },
    {
      "type": "text",
      "id": "light_mode_label",
      "default": "Light",
      "label": "Light button label"
    },
    {
      "type": "text",
      "id": "dark_mode_label",
      "default": "Dark",
      "label": "Dark button label"
    }
  ]
}
{% endschema %}
