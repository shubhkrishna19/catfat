{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="catfat-footer">
  <div class="page-width catfat-footer__inner">
    <span class="catfat-footer__topline">Smart lunchware. Better deals.</span>

    <div class="catfat-footer__grid">
      <div class="catfat-footer__brand">
        <h2 class="catfat-footer__brand-title">CatfatIndia for bold lunch picks and gifting wins.</h2>
        <p class="catfat-footer__brand-text">
          Bigger visuals, stronger value cues, and playful lunchware that helps shoppers compare fast and buy with confidence.
        </p>

        <div class="catfat-footer__trust">
          <span class="catfat-footer__trust-pill">Personalised picks</span>
          <span class="catfat-footer__trust-pill">Visible sale pricing</span>
          <span class="catfat-footer__trust-pill">Gift-friendly themes</span>
        </div>

        <div class="catfat-footer__contact-list">
          <a class="catfat-footer__contact-link" href="tel:+918383013068">
            <span>Call</span> +91 8383013068
          </a>
          <a class="catfat-footer__contact-link" href="mailto:support@catfatindia.com">
            <span>Email</span> support@catfatindia.com
          </a>
        </div>
      </div>

      <div>
        <h3 class="catfat-footer__heading">Shop</h3>
        <ul class="catfat-footer__links">
          <li><a href="/collections/all-products">All Products</a></li>
          <li><a href="/collections/lunch-box">Lunch Boxes</a></li>
          <li><a href="/collections/bottles-flasks">Bottles and Flasks</a></li>
          <li><a href="/collections/kids-collections">Kids Picks</a></li>
          <li><a href="/collections/india-s-biggest-lunch-sale-upto-80">Live Sale</a></li>
        </ul>
      </div>

      <div>
        <h3 class="catfat-footer__heading">Support</h3>
        <ul class="catfat-footer__links">
          <li><a href="/pages/contact-us">Contact Us</a></li>
          <li><a href="/collections/corporate-gifting-bulk-gifting">Bulk Gifting</a></li>
          <li><a href="/pages/terms-and-conditions">Terms and Conditions</a></li>
          <li><a href="{{ routes.account_url }}">My Account</a></li>
        </ul>
      </div>

      <div class="catfat-footer__signup">
        <h3 class="catfat-footer__heading">Get Coupons First</h3>
        <p class="catfat-footer__support-copy">
          Share your email for discount coupons, latest product updates, and early access to Catfat launches before the best products sell out.
        </p>

        {%- form 'customer', class: 'catfat-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="catfat-footer__newsletter-fields">
            <input
              type="email"
              name="contact[email]"
              class="catfat-footer__newsletter-input"
              value="{{ form.email }}"
              placeholder="Enter your email"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              required
            >
            <button type="submit" class="catfat-footer__newsletter-button">Unlock updates</button>
          </div>

          {%- if form.posted_successfully? -%}
            <p class="catfat-footer__newsletter-message">
              You are in. Watch your inbox for coupons and new-drop updates.
            </p>
          {%- elsif form.errors -%}
            <ul class="catfat-footer__newsletter-errors" role="alert">
              {%- for field in form.errors -%}
                <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        {%- endform -%}

        <div class="catfat-footer__social">
          <a href="https://wa.me/918383013068">WhatsApp</a>
          <a href="https://instagram.com/catfatindia">Instagram</a>
          <a href="https://facebook.com/catfatindia">Facebook</a>
        </div>
      </div>
    </div>

    <div class="catfat-footer__bottom">
      <p class="catfat-footer__bottom-copy">Copyright 2026 CatfatIndia. All rights reserved.</p>
      <p class="catfat-footer__bottom-note">Secure checkout for lunchware, gifting, and themed favourites.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
