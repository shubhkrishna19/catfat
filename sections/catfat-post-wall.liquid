{{ 'section-catfat-post-wall.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading | default: '@catfatindia'
  assign sub = section.settings.sub | default: 'Real lunches, real bottles, real routines — straight from our community.'
  assign handle = section.settings.handle | default: 'catfatindia'
  assign profile_url = 'https://instagram.com/' | append: handle
-%}

<section class="catfat-postwall">
  <div class="page-width">
    <div class="catfat-postwall__head" data-scrub data-scrub-y="28" data-scrub-opacity-from="0">
      <div class="catfat-postwall__head-copy">
        <span class="catfat-postwall__eyebrow">Post Wall</span>
        <h2 class="catfat-postwall__title">{{ heading }}</h2>
        <p class="catfat-postwall__sub">{{ sub }}</p>
      </div>
      <a class="catfat-postwall__follow" href="{{ profile_url }}" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
        </svg>
        <span>Follow on Instagram</span>
      </a>
    </div>

    <div class="catfat-postwall__grid">
      {%- for block in section.blocks -%}
        {%- assign post_image = block.settings.image -%}
        {%- assign post_video = block.settings.video -%}
        {%- assign post_url = block.settings.url -%}
        {%- assign post_caption = block.settings.caption -%}
        {%- assign post_is_video = false -%}
        {%- if post_video != blank -%}
          {%- assign post_is_video = true -%}
        {%- endif -%}

        <a class="catfat-postwall__tile catfat-postwall__tile--{{ forloop.index | modulo: 5 }}" href="{{ post_url | default: profile_url }}" target="_blank" rel="noopener" data-card-depth>
          {%- if post_is_video -%}
            <video class="catfat-postwall__media catfat-postwall__media--video" muted loop playsinline preload="none" aria-hidden="true">
              {%- for source in post_video.value.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- elsif post_image != blank -%}
            {{ post_image | image_url: width: 720 | image_tag: class: 'catfat-postwall__media', widths: '240, 360, 540, 720', loading: 'lazy', alt: post_caption | default: handle }}
          {%- else -%}
            <span class="catfat-postwall__placeholder" aria-hidden="true"></span>
          {%- endif -%}
          <span class="catfat-postwall__overlay">
            {%- if post_is_video -%}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="#fff" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#fff" stroke-width="2" aria-hidden="true">
                <path d="M21 16V7l-9-5-9 5v9l9 5 9-5z" />
              </svg>
            {%- endif -%}
            <span class="catfat-postwall__caption">{{ post_caption | default: 'View on Instagram' }}</span>
          </span>
        </a>
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        {%- for i in (1..8) -%}
          <a class="catfat-postwall__tile catfat-postwall__tile--placeholder catfat-postwall__tile--{{ forloop.index | modulo: 5 }}" href="{{ profile_url }}" target="_blank" rel="noopener" data-card-depth>
            <span class="catfat-postwall__placeholder" aria-hidden="true"></span>
            <span class="catfat-postwall__overlay">
              <span class="catfat-postwall__caption">Live posts coming soon</span>
            </span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Post Wall",
  "tag": "section",
  "max_blocks": 18,
  "settings": [
    { "type": "text", "id": "heading", "default": "@catfatindia", "label": "Heading" },
    { "type": "textarea", "id": "sub", "default": "Real lunches, real bottles, real routines — straight from our community.", "label": "Sub-copy" },
    { "type": "text", "id": "handle", "default": "catfatindia", "label": "Instagram handle (no @)" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Post image" },
        { "type": "video", "id": "video", "label": "Post video (reel)" },
        { "type": "url", "id": "url", "label": "Link to Instagram post" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    }
  ],
  "presets": [
    { "name": "Post Wall" }
  ]
}
{% endschema %}
