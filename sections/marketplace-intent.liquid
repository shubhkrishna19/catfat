{{ 'section-marketplace-intent.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign lunch_collection = collections['lunch-box']
  assign bottle_collection = collections['bottles-flasks']
  assign kids_collection = collections['kids-collections']
  assign arrivals_collection = collections['new-arrivals']

  assign hero_url = section.settings.hero_link
  if hero_url == blank
    assign hero_url = routes.collections_url
    if lunch_collection != blank and lunch_collection.url != blank
      assign hero_url = lunch_collection.url
    endif
  endif

  # Hero priority: theme editor upload > bundled brand image. Collection
  # auto-fetch is intentionally disabled here because it was picking up loose
  # product shots that didn't read as a hero.
  assign hero_media = section.settings.hero_image

  # Category card images: theme editor upload only. Bundled brand defaults are
  # rendered in the markup below when these are blank.
  assign lunch_media = section.settings.category_image_lunch
  assign bottle_media = section.settings.category_image_bottle
-%}

<section class="marketplace-intent">
  <div class="page-width">
    <div class="marketplace-intent__layout">
      <a href="{{ hero_url }}" class="marketplace-intent__hero" aria-label="Shop Catfat collections" data-scrub data-scrub-y="40" data-scrub-scale="0.96" data-scrub-opacity-from="0.2" data-scrub-layer="0.18">
        <div class="marketplace-intent__hero-media">
          {%- if hero_media != blank -%}
            {{
              hero_media
              | image_url: width: 1600
              | image_tag:
                class: 'marketplace-intent__hero-image',
                widths: '480, 720, 960, 1280, 1600',
                loading: 'lazy',
                alt: 'Catfat lunchware packed for school-day meals'
            }}
          {%- else -%}
            <img
              src="{{ 'catfat-smart-lunch-flatlay.jpg' | asset_url }}"
              class="marketplace-intent__hero-image"
              alt="Catfat lunchware flat-lay with bottle and Indian meal"
              loading="lazy"
              width="1600" height="1067">
          {%- endif -%}
        </div>

        <div class="marketplace-intent__hero-overlay"></div>
        <div class="marketplace-intent__hero-copy">
          <h2 class="marketplace-intent__hero-title">Smart Lunch for Everyday Life</h2>
          <span class="marketplace-intent__hero-button">Shop Now</span>
        </div>
      </a>

      <div class="marketplace-intent__panel" data-scrub data-scrub-y="32" data-scrub-opacity-from="0" data-scrub-from="0.1">
        <div class="marketplace-intent__heading">
          <h2 class="marketplace-intent__panel-title">Explore Our Range</h2>
          <p class="marketplace-intent__panel-copy">Made for school &amp; Indian meals.</p>
        </div>

        <div class="marketplace-intent__category-grid">
          <a
            href="{% if lunch_collection != blank and lunch_collection.url != blank %}{{ lunch_collection.url }}{% else %}/collections/all{% endif %}"
            class="marketplace-intent__category-card" data-card-depth
            aria-label="Browse Lunch Boxes"
          >
            <span class="marketplace-intent__category-media">
              {%- if lunch_media != blank -%}
                {{
                  lunch_media
                  | image_url: width: 720
                  | image_tag:
                    class: 'marketplace-intent__category-image',
                    widths: '180, 280, 420, 560, 720',
                    loading: 'lazy',
                    alt: 'Lunch Boxes'
                }}
              {%- else -%}
                <img src="{{ 'catfat-kids-panel.jpg' | asset_url }}" class="marketplace-intent__category-image" alt="Lunch Boxes" loading="lazy" width="1200" height="900">
              {%- endif -%}
            </span>
            <span class="marketplace-intent__category-title">Lunch Boxes</span>
          </a>

          <a
            href="{% if bottle_collection != blank and bottle_collection.url != blank %}{{ bottle_collection.url }}{% else %}/collections/all{% endif %}"
            class="marketplace-intent__category-card" data-card-depth
            aria-label="Browse Bottles and Flasks"
          >
            <span class="marketplace-intent__category-media">
              {%- if bottle_media != blank -%}
                {{
                  bottle_media
                  | image_url: width: 720
                  | image_tag:
                    class: 'marketplace-intent__category-image',
                    widths: '180, 280, 420, 560, 720',
                    loading: 'lazy',
                    alt: 'Bottles and Flasks'
                }}
              {%- else -%}
                <img src="{{ 'catfat-entry-portrait.jpg' | asset_url }}" class="marketplace-intent__category-image" alt="Bottles and Flasks" loading="lazy" width="1856" height="2304">
              {%- endif -%}
            </span>
            <span class="marketplace-intent__category-title">Bottles &amp; Flasks</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marketplace Intent",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (overrides auto fallback)" },
    { "type": "url", "id": "hero_link", "label": "Hero link (defaults to Lunch Boxes collection)" },
    { "type": "image_picker", "id": "category_image_lunch", "label": "Lunch Boxes card image (override)" },
    { "type": "image_picker", "id": "category_image_bottle", "label": "Bottles card image (override)" }
  ],
  "presets": [
    {
      "name": "Marketplace Intent"
    }
  ]
}
{% endschema %}
